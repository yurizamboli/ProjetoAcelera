<Page x:Class="ProjetoAcelera.Views.Artistas.TelaArtista"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="650" Width="1000"
        Background="#0A2A3A">

    <Grid Margin="20">

        <StackPanel>
            <!-- TÍTULO -->
            <TextBlock Text="ARTISTAS"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="Gold"
                       HorizontalAlignment="Center"
                       Margin="0,10"/>

            <!-- BUSCA -->
            <TextBox x:Name="txtBusca"
                     Height="35"
                     Margin="200,10"
                     Padding="10"
                     Text="Buscar nome do artista..."
                     Foreground="Gray"
                     GotFocus="TxtBusca_GotFocus"
                     LostFocus="TxtBusca_LostFocus"
                     TextChanged="TxtBusca_TextChanged"/>


            <!-- LISTA -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">

                <WrapPanel x:Name="painelArtistas"
                           HorizontalAlignment="Center"/>

            </ScrollViewer>

            <!-- VER MAIS -->
            <Button Content="Ver mais"
                    Width="120"
                    Height="35"
                    Margin="0,20"
                    HorizontalAlignment="Center"
                    Click="BtnVerMais_Click"/>

        </StackPanel>

    </Grid>
</Page>