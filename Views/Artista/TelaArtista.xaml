<Page x:Class="ProjetoAcelera.Views.Artistas.TelaArtista"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#0A2A3A">

    <Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto">

            <StackPanel Margin="25">

                <!-- TÍTULO -->
                <TextBlock Text="ARTISTAS"
                           FontSize="34"
                           FontWeight="Bold"
                           Foreground="#D4AF37"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,20"/>

                <!-- BUSCA -->
                <Border Background="#F3E6C9"
                        CornerRadius="12"
                        Padding="10"
                        Margin="140,0,140,25">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="txtBusca"
                                 Grid.Column="0"
                                 Height="38"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontSize="15"
                                 VerticalContentAlignment="Center"
                                 Text="Buscar nome do artista..."
                                 Foreground="Gray"
                                 GotFocus="TxtBusca_GotFocus"
                                 LostFocus="TxtBusca_LostFocus"
                                 TextChanged="TxtBusca_TextChanged"/>

                        <TextBlock Grid.Column="1"
                                   Text="🔍"
                                   FontSize="18"
                                   VerticalAlignment="Center"
                                   Margin="10,0,5,0"/>
                    </Grid>
                </Border>

                <!-- ARTISTAS -->
                <WrapPanel x:Name="painelArtistas"
                           HorizontalAlignment="Center"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>