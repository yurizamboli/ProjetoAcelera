<Page x:Class="ProjetoAcelera.Views.Artistas.TelaArtista"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="650" Width="1000"
        Background="#0A2A3A">

    <Grid Margin="20">

        <StackPanel>
            <!-- TÍTULO -->
            <TextBlock Text="ARTISTAS"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="Gold"
                       HorizontalAlignment="Center"
                       Margin="0,10"/>

            <!-- BUSCA COM LUPA -->
            <Grid Margin="100,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBox x:Name="txtBusca"
                         Grid.Column="0"
                         Height="35"
                         Padding="10"
                         Text="Buscar nome do artista..."
                         Foreground="Gray"
                         GotFocus="TxtBusca_GotFocus"
                         LostFocus="TxtBusca_LostFocus"
                         TextChanged="TxtBusca_TextChanged"/>
                
                <Button Grid.Column="1"
                        Content="🔍"
                        Width="35"
                        Height="35"
                        Background="#B8860B"
                        Foreground="White"
                        FontSize="16"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="5,0,0,0"/>
            </Grid>


            <!-- LISTA -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">

                <WrapPanel x:Name="painelArtistas"
                           HorizontalAlignment="Center"/>

            </ScrollViewer>

            <!-- VER MAIS -->
            <Button Content="Ver mais"
                    Width="120"
                    Height="35"
                    Margin="0,20"
                    HorizontalAlignment="Center"
                    Click="BtnVerMais_Click"/>

        </StackPanel>

    </Grid>
</Page>