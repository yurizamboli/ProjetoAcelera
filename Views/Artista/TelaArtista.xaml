<Window x:Class="ProjetoAcelera.Views.Artistas.TelaArtista"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Artistas"
        Height="650" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#0A2A3A">

    <Grid Margin="20">

        <StackPanel>
        <StackPanel Background="#F3E6C9" Height="60" VerticalAlignment="Top">

    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

        <TextBlock Text="Home" Margin="15,0"/>

        <!-- PROGRAMAÇÃO -->
        <Button Content="Programação"
                Margin="15,0"
                Background="Transparent"
                BorderThickness="0"
                Foreground="#1F3A5F"
                Cursor="Hand"
                Click="Programacao_Click"/>

        <TextBlock Text="Cultura" Margin="15,0"/>

        <!-- ARTISTAS -->
        <TextBlock Text="Artistas"
           Margin="15,0"
           Foreground="Black"
           FontWeight="Bold"/>

         <!-- NOSSA CIDADE -->
        <Button Content="Nossa Cidade"
                Margin="15,0"
                Background="Transparent"
                BorderThickness="0"
                Click="NossaCidade_Click"/>

        <!-- CONTA -->
        <Button Content="Conta"
                Margin="15,0"
                Background="Transparent"
                BorderThickness="0"
                Click="Conta_Click"/>
    </StackPanel>

</StackPanel>
            <!-- TÍTULO -->
            <TextBlock Text="ARTISTAS"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="Gold"
                       HorizontalAlignment="Center"
                       Margin="0,10"/>

            <!-- BUSCA -->
            <TextBox x:Name="txtBusca"
                     Height="35"
                     Margin="200,10"
                     Padding="10"
                     Text="Buscar nome do artista..."
                     Foreground="Gray"
                     GotFocus="TxtBusca_GotFocus"
                     LostFocus="TxtBusca_LostFocus"
                     TextChanged="TxtBusca_TextChanged"/>


            <!-- LISTA -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">

                <WrapPanel x:Name="painelArtistas"
                           HorizontalAlignment="Center"/>

            </ScrollViewer>

            <!-- VER MAIS -->
            <Button Content="Ver mais"
                    Width="120"
                    Height="35"
                    Margin="0,20"
                    HorizontalAlignment="Center"
                    Click="BtnVerMais_Click"/>

        </StackPanel>

    </Grid>
</Window>