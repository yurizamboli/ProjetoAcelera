<Window x:Class="ProjetoAcelera.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login" Height="500" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#0B2A3A">

	<Grid>
		<!-- Ngc central -->
		<Border Width="650" Height="auto"
                Background="#F5E6C8"
                CornerRadius="15"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="20">

			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="1*" />
					<ColumnDefinition Width="5" />
					<ColumnDefinition Width="1*" />
				</Grid.ColumnDefinitions>

				<!-- LADO ESQUERDO -->
				<StackPanel Grid.Column="0" VerticalAlignment="Center">
					<TextBlock Text="ALAHC"
                               FontSize="32"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="#1F3A5F"/>

					<TextBlock Text="Academia de Letras"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               Foreground="#1F3A5F"/>
				</StackPanel>

				<!-- LINHA DIVISÓRIA -->
				<Border Grid.Column="1"
                        Width="2"
                        Background="#2E8B57"
                        Margin="10,0"/>

				<!-- LOGIN -->
				<StackPanel Grid.Column="2"
                            VerticalAlignment="Center"
                            Margin="20">

					<TextBlock Text="Login"
                               FontSize="22"
                               FontWeight="Bold"
                               Margin="0,0,0,15"
                               Foreground="#1F3A5F"/>

					<!-- Usuario -->
					<TextBox x:Name="txtEmail"
                             Height="35"
                             Margin="0,5"
                             Padding="10"
                             Background="#EDEDED"
                             BorderThickness="0"
                             FontSize="14"
                             Text=""/>

					<!-- Senha -->
					<PasswordBox x:Name="txtSenha"
                                 Height="35"
                                 Margin="0,5"
                                 Padding="10"
                                 Background="#EDEDED"
                                 BorderThickness="0"
                                 FontSize="14"/>

					<!-- Botão -->
					<Button Content="ENTRAR!"
                            Height="40"
                            Margin="0,15,0,0"
                            Background="#1F3A5F"
                            Foreground="Gold"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="BtnLogin_Click"/>

					<Button Content="Não possui conta? Cadastre-se!"
							Height="40"
							Margin="0,15,0,0"
							Background="#1F3A5F"
							Foreground="Gold"
							FontWeight="Bold"
							BorderThickness="0"
							Cursor="Hand"
							Click="BtnCadastrarTela_Click"/>
                    <!--LEMBRAR DE TIRAR ESSE BOTAO AQ (SÓ PRA TESTE) -->
                    <Button Content="IR PARA OBRAS"
                            Width="120"
                            Height="30"
                            Margin="0,10,0,0"
                            Background="Transparent"
                            Foreground="Gray"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="BtnTesteObras_Click"/>

                    <Button Content="Teste Tela"
                            Width="120"
                            Height="30"
                            Margin="0,0,0,0"
                            Background="#1F3A5F"
                            Foreground="Gold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="BtnTesteFormatacao_Click"/>
                </StackPanel>
			</Grid>
		</Border>
	</Grid>
</Window>