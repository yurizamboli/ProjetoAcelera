<Window x:Class="ProjetoAcelera.Views.Home.Home"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Home" Height="600" Width="900"
        Background="#0B2A3A">

    <Grid>
        <!-- HEADER GRID -->
        <Grid Background="#0B2A3A">
            <!-- MENU SUPERIOR -->
            <StackPanel Background="#F3E6C9" Height="60" VerticalAlignment="Top">

                <!-- TÍTULO -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                    <TextBlock Text="ACADEMIA DE LETRAS ARTES E HISTÓRIA DE CRUZEIRO"
                               FontWeight="Bold"
                               FontSize="16"
                               Foreground="#1F3A5F"/>
                </StackPanel>

                <!-- MENU -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Home" Margin="15,0"/>

                    <!-- PROGRAMAÇÃO -->
                    <TextBlock Text="Progamação"
                               Margin="15,0"
                               Foreground="Black"
                               FontWeight="Bold"/>
                    <TextBlock Text="Cultura" Margin="15,0"/>

                    <!-- BOTÃO ARTISTAS -->
                    <Button Content="Artistas"
                            Margin="15,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#1F3A5F"
                            Cursor="Hand"
                            Click="Artistas_Click"/>

                    <!-- BOTÃO NOSSA CIDADE -->
                    <Button Content="Nossa Cidade"
                            Margin="15,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#1F3A5F"
                            Cursor="Hand"
                            Click="NossaCidade_Click"/>

                    <!-- BOTÃO CONTA -->
                    <Button Content="Conta"
                            Margin="15,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#1F3A5F"
                            Cursor="Hand"
                            Click="Conta_Click"/>
                </StackPanel>
            </StackPanel>

            <!-- CONTEÚDO PRINCIPAL -->
            <Grid Margin="0,120,0,0">

                <!-- Botão esquerda -->
                <Button Content="◀"
                        Width="40"
                        Height="40"
                        HorizontalAlignment="Left"
                        Margin="20"
                        VerticalAlignment="Center"
                        Click="BtnAnterior_Click"/>

                <!-- Botão direita -->
                <Button Content="▶"
                        Width="40"
                        Height="40"
                        HorizontalAlignment="Right"
                        Margin="20"
                        VerticalAlignment="Center"
                        Click="BtnProximo_Click"/>

                <!-- CARDS -->
                <Grid HorizontalAlignment="Center" Width="700">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <!-- CARD ESQUERDO -->
                    <Border Grid.Column="0"
                            Background="#EDE3D1"
                            BorderBrush="#B8860B"
                            BorderThickness="2"
                            CornerRadius="10"
                            Margin="10"
                            Padding="10">

                        <StackPanel>

                            <TextBlock Text="EVENTO"
                                       HorizontalAlignment="Center"
                                       FontWeight="Bold"
                                       Margin="0,0,0,10"/>

                            <Image x:Name="imgEvento"
                                   Height="200"
                                   Stretch="UniformToFill"/>

                            <TextBlock x:Name="txtTitulo"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       TextAlignment="Center"
                                       Margin="0,10,0,0"/>

                            <TextBlock x:Name="txtData"
                                       TextAlignment="Center"/>

                            <Button Content="VER PROGRAMAÇÃO"
                                    Margin="0,10,0,0"
                                    Background="#1E3A5F"
                                    Foreground="White"/>
                        </StackPanel>
                    </Border>

                    <!-- CARD DIREITO -->
                    <Border Grid.Column="1"
                            Background="#EDE3D1"
                            BorderBrush="#B8860B"
                            BorderThickness="2"
                            CornerRadius="10"
                            Margin="10"
                            Padding="15">

                        <StackPanel>

                            <TextBlock x:Name="txtDescricao"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,10"/>

                            <TextBlock x:Name="txtDetalhes"
                                       TextWrapping="Wrap"
                                       FontSize="12"/>

                        </StackPanel>
                    </Border>

                </Grid>

            </Grid>
        </Grid>
    </Grid>
</Window>
