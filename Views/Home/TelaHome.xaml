<Page x:Class="ProjetoAcelera.Views.Home.TelaHome"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"    
        Height="650" Width="900"
        MinWidth="700" MinHeight="1050"
        Background="#0B2A3A">
    <Page.Resources>

        <!-- ── Aqui fica os botões de navegação ── -->
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Foreground"       Value="#1F3A5F"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="FontFamily"       Value="Georgia"/>
            <Setter Property="Padding"          Value="12,5"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="brd" Background="Transparent" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="brd" Property="Background" Value="#E0CFA0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="brd" Property="Background" Value="#C8B880"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Botão CTA (azul escuro) ── -->
        <Style x:Key="CTAButtonStyle" TargetType="Button">
            <Setter Property="Background"       Value="#1F3A5F"/>
            <Setter Property="Foreground"       Value="#F3E6C9"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="FontFamily"       Value="Georgia"/>
            <Setter Property="FontSize"         Value="11"/>
            <Setter Property="Padding"          Value="18,8"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="brd" Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="brd" Property="Background" Value="#2A4D7F"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="brd" Property="Background" Value="#162B45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Botão seta do carrossel ── -->
        <Style x:Key="ArrowButtonStyle" TargetType="Button">
            <Setter Property="Background"       Value="#1F3A5F"/>
            <Setter Property="Foreground"       Value="#F3E6C9"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Width"            Value="36"/>
            <Setter Property="Height"           Value="36"/>
            <Setter Property="FontSize"         Value="14"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="brd" Background="{TemplateBinding Background}" CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="brd" Property="Background" Value="#B8860B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Page.Resources>

    <!-- Layout mais bonitinho Header fixo no topo + conteúdo que ocupa o restante -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- ── Carrossel dos eventos ── -->
                <Grid Margin="20,16,20,8">

                    <!-- Seta de voltar -->
                    <Button Style="{StaticResource ArrowButtonStyle}"
                            Content="◀"
                            HorizontalAlignment="Left" VerticalAlignment="Center"
                            Panel.ZIndex="1"
                            Click="BtnAnterior_Click"/>

                    <!-- Seta de próximo -->
                    <Button Style="{StaticResource ArrowButtonStyle}"
                            Content="▶"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Panel.ZIndex="1"
                            Click="BtnProximo_Click"/>

                    <!-- Cards que ficam lado a lado; Margin lateral deixa espaço para as setas -->
                    <Grid Margin="46,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Card esquerdo, imagem e os dados do evento -->
                        <Border Grid.Column="0"
                                Background="#EDE3D1" BorderBrush="#B8860B"
                                BorderThickness="1.5" CornerRadius="10"
                                Margin="0,0,5,0" Padding="14">
                            <StackPanel>
                                <TextBlock Text="EVENTO EM DESTAQUE"
                                           HorizontalAlignment="Center"
                                           FontFamily="Georgia" FontWeight="Bold"
                                           FontSize="10" Foreground="#8B6914"
                                           Margin="0,0,0,8"/>


                                <Border CornerRadius="6" ClipToBounds="True" Height="200">
                                    <Image x:Name="imgEvento"
                                           Source="/ImagemAcelera/evento1.png"
                                           Stretch="UniformToFill"
                                           />
                                    
                                </Border>

                                <TextBlock x:Name="txtTitulo"
                                           FontFamily="Georgia" FontSize="16" FontWeight="Bold"
                                           Foreground="#1F3A5F" TextAlignment="Center"
                                           TextWrapping="Wrap" Margin="0,10,0,4"/>

                                <TextBlock x:Name="txtData"
                                           TextAlignment="Center" FontFamily="Georgia"
                                           FontSize="13" Foreground="#8B6914" Margin="0,0,0,10"/>

                                <Button Content="VER PROGRAMAÇÃO"
                                        Style="{StaticResource CTAButtonStyle}"
                                        HorizontalAlignment="Center"
                                        Click="Programacao_Click"/>
                            </StackPanel>
                        </Border>

                        <!-- Card direito, com sua descrição e detalhes -->
                        <Border Grid.Column="1"
                                Background="#EDE3D1" BorderBrush="#B8860B"
                                BorderThickness="1.5" CornerRadius="10"
                                Margin="5,0,0,0" Padding="16">
                            <StackPanel>
                                <TextBlock x:Name="txtDescricao"
                                           FontFamily="Georgia" FontWeight="Bold"
                                           FontSize="15" Foreground="#1F3A5F"
                                           TextWrapping="Wrap" Margin="0,0,0,12"/>

                                <Rectangle Height="1" Fill="#B8860B" Margin="0,0,0,12"/>

                                <TextBlock x:Name="txtDetalhes"
                                           TextWrapping="Wrap" FontFamily="Georgia"
                                           FontSize="12" Foreground="#444444" LineHeight="20"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>

                <!-- ── Cultura da região ── -->
                <Border Background="#EDE3D1" Margin="20,6" CornerRadius="10" Padding="20,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="CULTURA DA REGIÃO"
                                       FontFamily="Georgia" FontSize="20"
                                       FontWeight="Bold" Foreground="#1F3A5F"/>
                            <TextBlock Text="Eventos, religiões, festas, artesanatos e muito mais."
                                       FontFamily="Georgia" FontSize="12" Foreground="#666666"
                                       Margin="0,4,0,12" TextWrapping="Wrap"/>
                            <Button Content="VEJA MAIS"
                                    Style="{StaticResource CTAButtonStyle}"
                                    HorizontalAlignment="Left" Click="Button_Click"/>
                        </StackPanel>

                        <!-- Imagem ilustrativa à direita -->
                        <Border Grid.Column="1" Width="120" Height="85"
                                CornerRadius="8" ClipToBounds="True"
                                Background="#C8B48A" Margin="14,0,0,0">
                            <Image Source="/ImagemAcelera/museu.png" Stretch="UniformToFill"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- ── Artistas em destaque ── -->
                <Border Background="#0D3348" Margin="20,6" CornerRadius="10"
                        BorderBrush="#B8860B" BorderThickness="1" Padding="20,16">
                    <StackPanel>
                        <TextBlock Text="ARTISTAS EM DESTAQUE"
                                   FontFamily="Georgia" FontSize="16" FontWeight="Bold"
                                   Foreground="#F3E6C9" HorizontalAlignment="Center"
                                   Margin="0,0,0,14"/>

                        <!-- Círculos dos artistas — storys do instagram -->
                        <WrapPanel HorizontalAlignment="Center">
                            <Border Width="70" Height="70" CornerRadius="35"
                                    Background="#1F3A5F" BorderBrush="#B8860B"
                                    BorderThickness="2" Margin="10,0" ClipToBounds="True">
                                <Image Source="/ImagemAcelera/AvatarPadrao.png" Stretch="UniformToFill"/>
                            </Border>
                            <Border Width="70" Height="70" CornerRadius="35"
                                    Background="#1F3A5F" BorderBrush="#B8860B"
                                    BorderThickness="2" Margin="10,0" ClipToBounds="True">
                                <Image Source="/ImagemAcelera/AvatarPadrao.png" Stretch="UniformToFill"/>
                            </Border>
                            <Border Width="70" Height="70" CornerRadius="35"
                                    Background="#1F3A5F" BorderBrush="#B8860B"
                                    BorderThickness="2" Margin="10,0" ClipToBounds="True">
                                <Image Source="/ImagemAcelera/AvatarPadrao.png" Stretch="UniformToFill"/>
                            </Border>
                        </WrapPanel>

                        <Button Content="VEJA MAIS ARTISTAS"
                                Style="{StaticResource CTAButtonStyle}"
                                Background="#B8860B"
                                HorizontalAlignment="Center"
                                Margin="0,14,0,0"
                                Click="Artistas_Click"/>
                    </StackPanel>
                </Border>

                <!-- Conheça Cruzeiro -->
                <!-- Height="160" é mínimo; cresce via ViewBox se quiser -->
                <Border Margin="20,6,20,20" CornerRadius="10" ClipToBounds="True" Height="170">
                    <Grid>
                        <Image Source="/ImagemAcelera/cruzeiro.png" Stretch="UniformToFill"/>


                        <Border Background="#90000000"/>

                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="CONHEÇA CRUZEIRO"
                                       Foreground="#F3E6C9" FontFamily="Georgia"
                                       FontSize="22" FontWeight="Bold"
                                       HorizontalAlignment="Center" Margin="0,0,0,6"/>
                            <TextBlock Text="O orgulho do Vale do Paraíba"
                                       Foreground="#EDD89A" FontFamily="Georgia"
                                       FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                            <Button Content="VEJA MAIS"
                                    Style="{StaticResource CTAButtonStyle}"
                                    HorizontalAlignment="Center"
                                    Click="NossaCidade_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Arabesco do rodapé -->
                <TextBlock Text="❧" HorizontalAlignment="Center"
                           Foreground="#B8860B" FontSize="20" Margin="0,0,0,18"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>