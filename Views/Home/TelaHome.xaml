<Page x:Class="ProjetoAcelera.Views.Home.TelaHome"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"    
        Background="#0B2A3A">
    <Page.Resources>

        <!-- ── Aqui fica os botões de navegação ── -->
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Foreground"       Value="#1F3A5F"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="FontFamily"       Value="Georgia"/>
            <Setter Property="Padding"          Value="12,5"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="brd" Background="Transparent" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="brd" Property="Background" Value="#E0CFA0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="brd" Property="Background" Value="#C8B880"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Botão CTA (azul escuro) ── -->
        <Style x:Key="CTAButtonStyle" TargetType="Button">
            <Setter Property="Background"       Value="#1F3A5F"/>
            <Setter Property="Foreground"       Value="#F3E6C9"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="FontFamily"       Value="Georgia"/>
            <Setter Property="FontSize"         Value="11"/>
            <Setter Property="Padding"          Value="18,8"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="brd" Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="brd" Property="Background" Value="#2A4D7F"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="brd" Property="Background" Value="#162B45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Botão seta do carrossel ── -->
        <Style x:Key="ArrowButtonStyle" TargetType="Button">
            <Setter Property="Background"       Value="#1F3A5F"/>
            <Setter Property="Foreground"       Value="#F3E6C9"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Width"            Value="36"/>
            <Setter Property="Height"           Value="36"/>
            <Setter Property="FontSize"         Value="14"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="brd" Background="{TemplateBinding Background}" CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="brd" Property="Background" Value="#B8860B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Page.Resources>

    <!-- Layout mais bonitinho Header fixo no topo + conteúdo que ocupa o restante -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
                  
        </Grid.RowDefinitions>


        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
            <StackPanel 
                        MinWidth="1080" MinHeight="1050"
                         MaxWidth="1366" 
                        Margin="0,0,0,70">

                <!-- ── Carrossel dos eventos ── -->
                <Border Margin="20,16" CornerRadius="24" Background="#0F3A5F" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Eventos em destaque"
                                   FontFamily="Georgia"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#F3E6C9"
                                   Margin="0,0,0,12"/>

                        <Grid MaxWidth="1000" MinHeight="420">
                            <Button Style="{StaticResource ArrowButtonStyle}"
                                    Content="◀"
                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                    Panel.ZIndex="1"
                                    Click="BtnAnterior_Click"/>

                            <Button Style="{StaticResource ArrowButtonStyle}"
                                    Content="▶"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Panel.ZIndex="1"
                                    Click="BtnProximo_Click"/>

                            <Grid Margin="54,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Background="#EDE3D1" BorderBrush="#B8860B"
                                        BorderThickness="1.5" CornerRadius="16"
                                        Margin="0,0,26,0" Padding="18">
                                    <StackPanel>
                                        <TextBlock Text="EVENTO EM DESTAQUE"
                                                   HorizontalAlignment="Center"
                                                   FontFamily="Georgia" FontWeight="Bold"
                                                   FontSize="11" Foreground="#8B6914"
                                                   Margin="0,0,0,10"/>

                                        <Border CornerRadius="10" ClipToBounds="True" Height="340" Width="330">
                                            <Image x:Name="imgEvento"
                                                   Source="/ImagemAcelera/evento1.png"
                                                   Stretch="UniformToFill"/>
                                        </Border>

                                        <TextBlock x:Name="txtTitulo"
                                                   FontFamily="Georgia" FontSize="18" FontWeight="Bold"
                                                   Foreground="#1F3A5F" TextAlignment="Center"
                                                   TextWrapping="Wrap" Margin="0,14,0,4"/>

                                        <TextBlock x:Name="txtData"
                                                   TextAlignment="Center" FontFamily="Georgia"
                                                   FontSize="13" Foreground="#8B6914" Margin="0,0,0,12"/>

                                        <Button Content="VER PROGRAMAÇÃO"
                                                Style="{StaticResource CTAButtonStyle}"
                                                HorizontalAlignment="Center"
                                                Click="Programacao_Click"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1"
                                        Background="#EDE3D1" BorderBrush="#B8860B"
                                        BorderThickness="1.5" CornerRadius="16"
                                        Padding="20" Margin="5,0,0,0">
                                    <StackPanel>
                                        <TextBlock x:Name="txtDescricao"
                                                   FontFamily="Georgia" FontWeight="Bold"
                                                   FontSize="14" Foreground="#1F3A5F"
                                                   TextWrapping="Wrap" Margin="0,0,0,12" LineHeight="22"/>

                                        <Rectangle Height="1" Fill="#B8860B" Margin="0,0,0,12"/>

                                        <TextBlock x:Name="txtDetalhes"
                                                   TextWrapping="Wrap" FontFamily="Georgia"
                                                   FontSize="12" Foreground="#444444" LineHeight="22"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </StackPanel>
                </Border>
                <Border Background="#0D3348" CornerRadius="10"
                        BorderBrush="#B8860B" BorderThickness="1" Padding="20,16" MinWidth="1204" Margin="20,16">
                    <StackPanel>
                        <TextBlock Text="ARTISTAS EM DESTAQUE"
                                   FontFamily="Georgia" FontSize="16" FontWeight="Bold"
                                   Foreground="#F3E6C9" HorizontalAlignment="Center"
                                   Margin="0,0,0,14"/>

                        <WrapPanel HorizontalAlignment="Center">
                            <Border Width="70" Height="70" CornerRadius="35"
                                    Background="#1F3A5F" BorderBrush="#B8860B"
                                    BorderThickness="2" Margin="10,0" ClipToBounds="True">
                                <Image Source="/ImagemAcelera/AvatarPadrao.png" Stretch="UniformToFill"/>
                            </Border>
                            <Border Width="70" Height="70" CornerRadius="35"
                                    Background="#1F3A5F" BorderBrush="#B8860B"
                                    BorderThickness="2" Margin="10,0" ClipToBounds="True">
                                <Image Source="/ImagemAcelera/AvatarPadrao.png" Stretch="UniformToFill"/>
                            </Border>
                            <Border Width="70" Height="70" CornerRadius="35"
                                    Background="#1F3A5F" BorderBrush="#B8860B"
                                    BorderThickness="2" Margin="10,0" ClipToBounds="True">
                                <Image Source="/ImagemAcelera/AvatarPadrao.png" Stretch="UniformToFill"/>
                            </Border>
                        </WrapPanel>

                        <Button Content="VEJA MAIS ARTISTAS"
                                Style="{StaticResource CTAButtonStyle}"
                                Background="#B8860B"
                                HorizontalAlignment="Center"
                                Margin="0,14,0,0"
                                Click="Artistas_Click"/>
                    </StackPanel>
                </Border>

                <Border Background="#EDE3D1" CornerRadius="16" Padding="20" MinWidth="1196" Height="341" Margin="20,16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,14">
                            <Border Width="46" Height="46"
                                    CornerRadius="23"
                                    Background="#1F3A5F"
                                    ClipToBounds="True">
                                <Image Source="/ImagemAcelera/AvatarPadrao.png"
                                       Stretch="UniformToFill"/>
                            </Border>
                            <StackPanel Margin="12,0">
                                <TextBlock Text="Compartilhe com a comunidade"
                                           FontFamily="Georgia"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="#1F3A5F"/>
                                <TextBlock x:Name="txtUsuarioPostagem"
                                           FontFamily="Georgia"
                                           FontSize="12"
                                           Foreground="#666666"/>
                            </StackPanel>
                        </StackPanel>

                        <TextBox x:Name="txtPostTexto"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Height="120"
                                 FontFamily="Georgia"
                                 FontSize="13"
                                 Foreground="#1F3A5F"
                                 Background="White"
                                 BorderBrush="#B8860B"
                                 BorderThickness="1"
                                 Padding="12"
                                 Text=""
                                 VerticalScrollBarVisibility="Auto"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,14,0,0">
                            <Button Content="Adicionar foto"
                                    Style="{StaticResource CTAButtonStyle}"
                                    Background="#B8860B"
                                    Click="AdicionarFoto_Click"
                                    Margin="0,0,8,0"/>
                            <Button Content="Adicionar vídeo"
                                    Style="{StaticResource CTAButtonStyle}"
                                    Background="#1F3A5F"
                                    Click="AdicionarVideo_Click"/>
                        </StackPanel>

                        <TextBlock x:Name="txtAnexoStatus"
                                   FontFamily="Georgia"
                                   FontSize="12"
                                   Foreground="#444444"
                                   Margin="0,10,0,0" Height="21"/>

                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="txtStatusPostagem"
                                       Grid.Column="0"
                                       FontFamily="Georgia"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="#1F3A5F"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Left"/>
                            <Button Grid.Column="1"
                                    Content="POSTAR"
                                    Style="{StaticResource CTAButtonStyle}"
                                    Width="140"
                                    Click="Postar_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border BorderBrush="#B8860B" BorderThickness="2" Margin="20,16" CornerRadius="16" Padding="5" MinWidth="1196" MinHeight="400">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  MaxHeight="500">

                        <StackPanel x:Name="painelFeedPublicacoes" />

                    </ScrollViewer>
                </Border>

                <Border Margin="20,6,20,20" CornerRadius="10" ClipToBounds="True" Height="170">
                    <Grid>
                        <Image Source="/ImagemAcelera/cruzeiro.png" Stretch="UniformToFill"/>


                        <Border Background="#90000000"/>

                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="CONHEÇA CRUZEIRO"
                                       Foreground="#F3E6C9" FontFamily="Georgia"
                                       FontSize="22" FontWeight="Bold"
                                       HorizontalAlignment="Center" Margin="0,0,0,6"/>
                            <TextBlock Text="O orgulho do Vale do Paraíba"
                                       Foreground="#EDD89A" FontFamily="Georgia"
                                       FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                            <Button Content="VEJA MAIS"
                                    Style="{StaticResource CTAButtonStyle}"
                                    HorizontalAlignment="Center"
                                    Click="NossaCidade_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <TextBlock Text="❧" HorizontalAlignment="Center"
                           Foreground="#B8860B" FontSize="20" Margin="0,0,0,18"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>