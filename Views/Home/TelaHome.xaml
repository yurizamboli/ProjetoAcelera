<Window x:Class="ProjetoAcelera.Views.Home.TelaHome"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Academia de Letras, Artes e História de Cruzeiro"
        Height="Auto" Width="900"
        Background="#0B2A3A"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Estilo de botão do menu (navegação) -->
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#1F3A5F"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="brd" Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="brd" Property="Background" Value="#E8D8B0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="brd" Property="Background" Value="#D4C090"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo botão principal -->
        <Style x:Key="CTAButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1F3A5F"/>
            <Setter Property="Foreground" Value="#F3E6C9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="brd" Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="brd" Property="Background" Value="#2A4D7F"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="brd" Property="Background" Value="#162B45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo botão seta carrossel -->
        <Style x:Key="ArrowButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1F3A5F"/>
            <Setter Property="Foreground" Value="#F3E6C9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="brd" Background="{TemplateBinding Background}" CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="brd" Property="Background" Value="#B8860B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header fixo -->
            <RowDefinition Height="*"/>
            <!-- Conteúdo rolável -->
        </Grid.RowDefinitions>

        <!--Cabeçalho fixo -->
        <Border Grid.Row="0" Background="#F3E6C9" Padding="0,8,0,0">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="8" Opacity="0.15" ShadowDepth="2" Direction="270"/>
            </Border.Effect>
            <StackPanel>
                <!-- Título / Logo -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                    <Border Width="32" Height="32" CornerRadius="16" Background="#1F3A5F" Margin="0,0,10,0">
                        <TextBlock Text="A" Foreground="#F3E6C9" FontFamily="Georgia" FontSize="16"
                                   FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="ACADEMIA DE LETRAS, ARTES E HISTÓRIA DE CRUZEIRO"
                               FontWeight="Bold" FontSize="14" FontFamily="Georgia"
                               Foreground="#1F3A5F" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Arabesco dourado -->
                <Rectangle Height="1" Fill="#B8860B" Margin="20,0"/>

                <!-- Menu de navegação -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                    <TextBlock Text="Home" Margin="12,0" FontFamily="Georgia" FontSize="13"
                               Foreground="#1F3A5F" FontWeight="Bold" VerticalAlignment="Center"/>

                    <Button Content="Programação" Style="{StaticResource MenuButtonStyle}" Click="Programacao_Click"/>
                    <Button Content="Cultura"      Style="{StaticResource MenuButtonStyle}" Click="Cultura_Click"/>
                    <Button Content="Artistas"     Style="{StaticResource MenuButtonStyle}" Click="Artistas_Click"/>
                    <Button Content="Nossa Cidade" Style="{StaticResource MenuButtonStyle}" Click="NossaCidade_Click"/>
                    <Button Content="Conta"        Style="{StaticResource MenuButtonStyle}" Click="Conta_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Rolagem com scroll  -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Carrosel de eventos -->
                <Grid Margin="20,16,20,8">
                    
                    <!-- Botão Anterior -->
                    <Button Style="{StaticResource ArrowButtonStyle}"
                            Content="◀"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Panel.ZIndex="1"
                            Click="BtnAnterior_Click"/>

                    <!-- Botão Próximo -->
                    <Button Style="{StaticResource ArrowButtonStyle}"
                            Content="▶"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Panel.ZIndex="1"
                            Click="BtnProximo_Click"/>

                    <!-- Cards lado a lado -->
                    <Grid HorizontalAlignment="Center" Width="780" Margin="44,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Imagem com informação -->
                        <Border Grid.Column="0"
                                Background="#EDE3D1"
                                BorderBrush="#B8860B"
                                BorderThickness="1.5"
                                CornerRadius="10"
                                Margin="0,0,6,0"
                                Padding="14">
                            <StackPanel>
                                <TextBlock Text="EVENTO EM DESTAQUE"
                                           HorizontalAlignment="Center"
                                           FontFamily="Georgia"
                                           FontWeight="Bold"
                                           FontSize="10"
                                           Foreground="#8B6914"
                                           Margin="0,0,0,10"/>

                                <!-- Imagem do evento -->
                                <Border CornerRadius="6" ClipToBounds="True" Height="190">
                                    <Image x:Name="imgEvento"
                                           Source="/ImagemAcelera/LogoALAHC.png"
                                           Stretch="UniformToFill"/>
                                </Border>

                                <TextBlock x:Name="txtTitulo"
                                           FontFamily="Georgia"
                                           FontSize="17"
                                           FontWeight="Bold"
                                           Foreground="#1F3A5F"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Margin="0,10,0,4"/>

                                <TextBlock x:Name="txtData"
                                           TextAlignment="Center"
                                           FontFamily="Georgia"
                                           FontSize="13"
                                           Foreground="#8B6914"
                                           Margin="0,0,0,10"/>

                                <Button Content="VER PROGRAMAÇÃO"
                                        Style="{StaticResource CTAButtonStyle}"
                                        HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Descrição no card -->
                        <Border Grid.Column="1"
                                Background="#EDE3D1"
                                BorderBrush="#B8860B"
                                BorderThickness="1.5"
                                CornerRadius="10"
                                Margin="6,0,0,0"
                                Padding="16">
                            <StackPanel>
                                <TextBlock x:Name="txtDescricao"
                                           FontFamily="Georgia"
                                           FontWeight="Bold"
                                           FontSize="15"
                                           Foreground="#1F3A5F"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,12"/>

                                <Rectangle Height="1" Fill="#B8860B" Margin="0,0,0,12"/>

                                <TextBlock x:Name="txtDetalhes"
                                           TextWrapping="Wrap"
                                           FontFamily="Georgia"
                                           FontSize="12"
                                           Foreground="#444444"
                                           LineHeight="20"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Cultura da região -->
                <Border Background="#EDE3D1"
                        Margin="20,6"
                        CornerRadius="10"
                        Padding="20,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="CULTURA DA REGIÃO"
                                       FontFamily="Georgia"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="#1F3A5F"/>
                            <TextBlock Text="Eventos, religiões, festas, artesanatos e muito mais."
                                       FontFamily="Georgia"
                                       FontSize="12"
                                       Foreground="#666666"
                                       Margin="0,4,0,10"
                                       TextWrapping="Wrap"/>
                            <Button Content="VEJA MAIS"
                                    Style="{StaticResource CTAButtonStyle}"
                                    HorizontalAlignment="Left"/>
                        </StackPanel>

                        <!-- Imagem ilustrativa (placeholder) -->
                        <Border Grid.Column="1"
                                Width="110" Height="80"
                                CornerRadius="8"
                                Background="#C8B48A"
                                Margin="12,0,0,0">
                            <Image Source="/ImagemAcelera/Museu.png" Stretch="UniformToFill"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- ── SEÇÃO: ARTISTAS EM DESTAQUE ── -->
                <Border Background="#0D3348"
                        Margin="20,6"
                        CornerRadius="10"
                        Padding="20,16">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#B8860B"/>
                    </Border.BorderBrush>
                    <Border.BorderThickness>1</Border.BorderThickness>

                    <StackPanel>
                        <TextBlock Text="ARTISTAS EM DESTAQUE"
                                   FontFamily="Georgia"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#F3E6C9"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,14"/>

                        <!-- Círculos dos artistas -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Border Width="64" Height="64" CornerRadius="32"
                                    Background="#1F3A5F" BorderBrush="#B8860B" BorderThickness="2"
                                    Margin="8,0"/>
                            <Border Width="64" Height="64" CornerRadius="32"
                                    Background="#1F3A5F" BorderBrush="#B8860B" BorderThickness="2"
                                    Margin="8,0"/>
                            <Border Width="64" Height="64" CornerRadius="32"
                                    Background="#1F3A5F" BorderBrush="#B8860B" BorderThickness="2"
                                    Margin="8,0"/>
                        </StackPanel>

                        <Button Content="VEJA MAIS ARTISTAS"
                                Style="{StaticResource CTAButtonStyle}"
                                Background="#B8860B"
                                HorizontalAlignment="Center"
                                Margin="0,14,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Conheça Cruzeiro -->
                <Border Margin="20,6,20,20" CornerRadius="10" ClipToBounds="True" Height="160">
                    <Grid>
                        <Image Source="/ImagemAcelera/cruzeiro.png" Stretch="UniformToFill"/>

                        <!-- Overlay escuro -->
                        <Border Background="#88000000" CornerRadius="0"/>

                        <!-- Conteúdo sobre a imagem -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="CONHEÇA CRUZEIRO"
                                       Foreground="#F3E6C9"
                                       FontFamily="Georgia"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="O orgulho do Vale do Paraíba"
                                       Foreground="#EDD89A"
                                       FontFamily="Georgia"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,12"/>
                            <Button Content="VEJA MAIS"
                                    Style="{StaticResource CTAButtonStyle}"
                                    HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Ornamento de rodapé -->
                <TextBlock Text="❧" HorizontalAlignment="Center"
                           Foreground="#B8860B" FontSize="18" Margin="0,0,0,16"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>