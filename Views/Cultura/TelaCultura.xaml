<Page x:Class="ProjetoAcelera.Views.Cultura.TelaCultura"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- FUNDO -->
    <Page.Background>
        <ImageBrush ImageSource="/ImagemAcelera/solid-navy-blue-concrete-textured-wall.jpg"
                    Stretch="UniformToFill"/>
    </Page.Background>

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <StackPanel Margin="22">

            <!-- TÍTULO -->
            <TextBlock Text="SOBRE NÓS"
                       FontFamily="Georgia"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="#F3E6C9"
                       Margin="0,0,0,10"/>

            <TextBlock Text="Academia de Letras, Artes e História de Cruzeiro"
                       FontFamily="Georgia"
                       FontSize="16"
                       Foreground="#D9D4C4"
                       Margin="0,0,0,24"/>

            <!-- SOBRE A ACADEMIA -->
            <Border Background="#EDE3D1"
                    CornerRadius="18"
                    Padding="20"
                    Margin="0,0,0,20">

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="190"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Margin="0,0,18,0">

                        <TextBlock Text="Quem Somos"
                                   FontFamily="Georgia"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#1F3A5F"
                                   Margin="0,0,0,12"/>

                        <TextBlock Text="A Academia de Letras, Artes e História de Cruzeiro tem como objetivo preservar, incentivar e divulgar a cultura, a memória e a identidade histórica da cidade de Cruzeiro e da região do Vale do Paraíba."
                                   FontFamily="Georgia"
                                   FontSize="13"
                                   Foreground="#444444"
                                   TextWrapping="Wrap"
                                   LineHeight="24"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="Por meio de eventos culturais, exposições, projetos artísticos e ações educacionais, buscamos aproximar a comunidade da arte, literatura e patrimônio histórico regional."
                                   FontFamily="Georgia"
                                   FontSize="13"
                                   Foreground="#444444"
                                   TextWrapping="Wrap"
                                   LineHeight="24"/>

                    </StackPanel>

                    <Border Grid.Column="1"
                            CornerRadius="14"
                            ClipToBounds="True"
                            Background="#C8B48A"
                            Height="150">

                        <Image Source="/ImagemAcelera/LogoALAHC.png"
                               Stretch="UniformToFill"/>

                    </Border>

                </Grid>
            </Border>

            <!-- SOBRE O PROJETO -->
            <Border Background="#0D3348"
                    CornerRadius="18"
                    Padding="20"
                    BorderBrush="#B8860B"
                    BorderThickness="1.5"
                    Margin="0,0,0,20">

                <StackPanel>

                    <TextBlock Text="Sobre o Projeto"
                               FontFamily="Georgia"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#F3E6C9"
                               Margin="0,0,0,12"/>

                    <TextBlock Text="O Projeto Acelera foi desenvolvido com o objetivo de modernizar a divulgação cultural da Academia de Letras, Artes e História de Cruzeiro."
                               FontFamily="Georgia"
                               FontSize="13"
                               Foreground="#E8DEC7"
                               TextWrapping="Wrap"
                               LineHeight="24"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="A plataforma permite o compartilhamento de eventos, programações, artistas em destaque e publicações da comunidade, criando um ambiente digital voltado à valorização da cultura regional."
                               FontFamily="Georgia"
                               FontSize="13"
                               Foreground="#E8DEC7"
                               TextWrapping="Wrap"
                               LineHeight="24"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="Além disso, o sistema busca aproximar artistas, visitantes e organizadores através de uma experiência moderna, acessível e interativa."
                               FontFamily="Georgia"
                               FontSize="13"
                               Foreground="#E8DEC7"
                               TextWrapping="Wrap"
                               LineHeight="24"/>

                </StackPanel>
            </Border>

            <!-- MISSÃO VISÃO VALORES -->
            <Grid Margin="0,0,0,20">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- MISSÃO -->
                <Border Grid.Column="0"
                        Background="#EDE3D1"
                        CornerRadius="16"
                        Padding="18"
                        Margin="0,0,10,0">

                    <StackPanel>

                        <TextBlock Text="Missão"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#1F3A5F"/>

                        <TextBlock Text="Promover a cultura, conhecimento e memórias da nossa cidade menina!"
                                   TextWrapping="Wrap"
                                   Margin="0,10,0,0"
                                   Foreground="#444"/>

                    </StackPanel>
                </Border>

                <!-- VISÃO -->
                <Border Grid.Column="1"
                        Background="#EDE3D1"
                        CornerRadius="16"
                        Padding="18"
                        Margin="5,0">

                    <StackPanel>

                        <TextBlock Text="Visão"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#1F3A5F"/>

                        <TextBlock Text="Conectar artistas, história e comunidade em um ambiente digital moderno e acessível."
                                   TextWrapping="Wrap"
                                   Margin="0,10,0,0"
                                   Foreground="#444"/>

                    </StackPanel>
                </Border>

                <!-- VALORES -->
                <Border Grid.Column="2"
                        Background="#EDE3D1"
                        CornerRadius="16"
                        Padding="18"
                        Margin="10,0,0,0">

                    <StackPanel>

                        <TextBlock Text="Valores"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#1F3A5F"/>

                        <TextBlock Text="Cultura, inclusão, memória histórica, arte e inovação."
                                   TextWrapping="Wrap"
                                   Margin="0,10,0,0"
                                   Foreground="#444"/>

                    </StackPanel>
                </Border>

            </Grid>

            <!-- TECNOLOGIAS -->
            <Border Background="#EDE3D1"
                    CornerRadius="18"
                    Padding="20"
                    Margin="0,0,0,20">

                <StackPanel>

                    <TextBlock Text="Tecnologias Utilizadas"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#1F3A5F"
                               Margin="0,0,0,16"/>

                    <WrapPanel>

                        <Border Background="#1F3A5F"
                                CornerRadius="10"
                                Padding="14,8"
                                Margin="0,0,10,10">
                            <TextBlock Text="C#"
                                       Foreground="White"
                                       FontWeight="Bold"/>
                        </Border>

                        <Border Background="#1F3A5F"
                                CornerRadius="10"
                                Padding="14,8"
                                Margin="0,0,10,10">
                            <TextBlock Text="WPF"
                                       Foreground="White"
                                       FontWeight="Bold"/>
                        </Border>

                        <Border Background="#1F3A5F"
                                CornerRadius="10"
                                Padding="14,8"
                                Margin="0,0,10,10">
                            <TextBlock Text="XAML"
                                       Foreground="White"
                                       FontWeight="Bold"/>
                        </Border>

                        <Border Background="#1F3A5F"
                                CornerRadius="10"
                                Padding="14,8"
                                Margin="0,0,10,10">
                            <TextBlock Text="GitHub"
                                       Foreground="White"
                                       FontWeight="Bold"/>
                        </Border>


                    </WrapPanel>

                </StackPanel>
            </Border>

            <!-- EQUIPE -->
