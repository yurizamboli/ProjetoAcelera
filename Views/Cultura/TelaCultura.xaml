<Page x:Class="ProjetoAcelera.Views.Cultura.TelaCultura"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Height="Auto" Width="1000"
      Background="#0A2A3A">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="CULTURA DA REGIÃO"
                       FontFamily="Georgia"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#F3E6C9"
                       Margin="0,0,0,10"/>

            <TextBlock Text="Conheça os traços culturais que tornam nossa cidade única: festas, religiões, artesanato e memória viva do Vale do Paraíba."
                       FontFamily="Georgia"
                       FontSize="14"
                       Foreground="#D9D4C4"
                       TextWrapping="Wrap"
                       Margin="0,0,0,24"/>

            <Border Background="#EDE3D1" CornerRadius="16" Padding="18" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                        <TextBlock Text="Cultura da Região"
                                   FontFamily="Georgia"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#1F3A5F"
                                   Margin="0,0,0,10"/>
                        <TextBlock Text="Eventos, religiões, festas, artesanatos e muito mais. A cultura local é uma celebração da identidade e da história do povo de Cruzeiro."
                                   FontFamily="Georgia"
                                   FontSize="13"
                                   Foreground="#444444"
                                   TextWrapping="Wrap"
                                   LineHeight="22"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Width="155"
                            Height="110"
                            CornerRadius="12"
                            ClipToBounds="True"
                            Background="#C8B48A">
                        <Image Source="/ImagemAcelera/museu.png"
                               Stretch="UniformToFill"/>
                    </Border>
                </Grid>
            </Border>

            <Border Background="#0D3348" CornerRadius="16" Padding="18" BorderBrush="#B8860B" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="CONHEÇA CRUZEIRO"
                               FontFamily="Georgia"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#F3E6C9"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="Descubra os pontos históricos, o orgulho do Vale do Paraíba e a memória viva que garante a beleza da nossa cidade."
                               FontFamily="Georgia"
                               FontSize="13"
                               Foreground="#EDD89A"
                               TextWrapping="Wrap"
                               LineHeight="22"
                               Margin="0,0,0,14"/>
                    <Button Content="VEJA MAIS"
                            Width="140"
                            HorizontalAlignment="Left"
                            Background="#B8860B"
                            Foreground="#F3E6C9"
                            BorderThickness="0"
                            Padding="10,6"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
