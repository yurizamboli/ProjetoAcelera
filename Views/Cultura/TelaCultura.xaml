                        </Border>

                    </WrapPanel>

                </StackPanel>
            </Border>

            <!-- FRASE -->
            <TextBlock Text='"Tecnologia e cultura caminhando juntas para preservar nossa história."'
                       FontStyle="Italic"
                       FontSize="16"
                       HorizontalAlignment="Center"
                       Foreground="#F3E6C9"
