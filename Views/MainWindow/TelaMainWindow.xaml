<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="ProjetoAcelera.Views.MainWindow.TelaMainWindow"
        Title="Academia de Letras, Artes e História de Cruzeiro"
        Height="650" Width="900"
        MinWidth="700" MinHeight="550"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Window.Background>
        <ImageBrush ImageSource="/ImagemAcelera/solid-navy-blue-concrete-textured-wall.jpg"
                    Stretch="UniformToFill"/>
    </Window.Background>
    
    <Window.Resources>
        <!-- SCROLLBAR PERSONALIZADA -->
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Background" Value="#D6C28F"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Background="#D6C28F">
                            <Track x:Name="PART_Track"
                           IsDirectionReversed="True"
                           Focusable="False">

                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                          Opacity="0"
                                          Focusable="False"/>
                                </Track.DecreaseRepeatButton>

                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Border Background="#B8860B"
                                                CornerRadius="6"
                                                Margin="2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>

                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                          Opacity="0"
                                          Focusable="False"/>
                                </Track.IncreaseRepeatButton>

                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="MenuButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#1F3A5F"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="brd" Background="Transparent" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="brd" Property="Background" Value="#E0CFA0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="brd" Property="Background" Value="#C8B880"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#F3E6C9" Padding="0,8,0,4">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="8"
                                  Opacity="0.18"
                                  ShadowDepth="2"
                                  Direction="270"/>
            </Border.Effect>

            <StackPanel>

                <Grid Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center">

                        <Border Width="32" Height="32"
                                CornerRadius="16"
                                Background="#1F3A5F"
                                ClipToBounds="True"
                                Margin="0,0,10,0">

                            <Image Source="/ImagemAcelera/LogoALAHC.png"
                                   Stretch="UniformToFill"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="ACADEMIA DE LETRAS, ARTES E HISTÓRIA DE CRUZEIRO"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   FontFamily="Georgia"
                                   Foreground="#1F3A5F"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="2"
                            Content="✕"
                            Width="32"
                            Height="32"
                            FontSize="18"
                            FontWeight="Bold"
                            Background="#1F3A5F"
                            Foreground="#B8860B"
                            BorderBrush="#B8860B"
                            BorderThickness="2"
                            HorizontalAlignment="Right"
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            Cursor="Hand"
                            Click="Fechar_Click">

                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="brd"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="4">

                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>

                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="brd" Property="Background" Value="#A52A2A"/>
                                                </Trigger>

                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="brd" Property="Background" Value="#7B1E1E"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>

                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

                <Rectangle Height="3">
                    <Rectangle.Fill>
                        <ImageBrush ImageSource="/ImagemAcelera/cor-dourada-abstrack-plano-de-fundo-design_805663-177.avif"
                    Stretch="UniformToFill"/>
                    </Rectangle.Fill>
                </Rectangle>
                <Border Margin="0,0,0,-3"
                        Padding="0,4,0,4">

                    <Border.Background>
                        <ImageBrush ImageSource="/ImagemAcelera/fundo-pintado-mao-da-aguarela_24972-1199.avif"
                                    Stretch="UniformToFill"/>
                    </Border.Background>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,3,0,0">

                    <Button Content="🏡  Início" Style="{StaticResource MenuButtonStyle}" Click="Home_Click"/>
                    <Button Content="🏞️  Nossa Cidade" Style="{StaticResource MenuButtonStyle}" Click="NossaCidade_Click"/>
                    <Button Content="📅  Programação" Style="{StaticResource MenuButtonStyle}" Click="Programacao_Click"/>
                    <Button Content="🎭  Artistas" Style="{StaticResource MenuButtonStyle}" Click="Artistas_Click"/>
                    <Button Content="❔  Sobre Nós" Style="{StaticResource MenuButtonStyle}" Click="Cultura_Click"/>
                    <Button x:Name="BtnConta" Content="👤 Perfil" Style="{StaticResource MenuButtonStyle}" Click="Conta_Click"/>
                    <Button x:Name="BtnLogin" Content="🔐 Entrar / Cadastrar" Style="{StaticResource MenuButtonStyle}" Click="Login_Click"/>

                </StackPanel>
                </Border>
            </StackPanel>
                
        </Border>

        <ScrollViewer x:Name="ScrollPrincipal"
              Grid.Row="1"
              VerticalScrollBarVisibility="Auto"
              HorizontalScrollBarVisibility="Disabled">

            <Grid MinHeight="{Binding ActualHeight, ElementName=ScrollPrincipal}">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Frame x:Name="SwitchFrame"
               Grid.Row="0"
               NavigationUIVisibility="Hidden"
               PreviewMouseWheel="SwitchFrame_PreviewMouseWheel"/>

                <!-- Espaço vazio que empurra o rodapé para baixo quando a tela é pequena -->
                <Border Grid.Row="1"
                Background="Transparent"/>

                <!-- Rodapé decorativo -->
                <StackPanel Grid.Row="2">

                    <Rectangle Height="4">
                        <Rectangle.Fill>
                            <ImageBrush ImageSource="/ImagemAcelera/cor-dourada-abstrack-plano-de-fundo-design_805663-177.avif"
                                Stretch="UniformToFill"/>
                        </Rectangle.Fill>
                    </Rectangle>

                    <Border Height="90"
                    Background="#F3E6C9">

                        <Image Source="/ImagemAcelera/frufru.png"
                       Width="188"
                       Height="120"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

                    </Border>

                </StackPanel>

            </Grid>

        </ScrollViewer>

    </Grid>
</Window>