<Window x:Class="ProjetoAcelera.Views.LoginRegistro.TelaTermosDeUso"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Termos de Uso"
        Height="500"
        Width="700"
        WindowStartupLocation="CenterScreen">
    <Window.Background>
        <ImageBrush ImageSource="/ImagemAcelera/solid-navy-blue-concrete-textured-wall.jpg"
                Stretch="UniformToFill"/>
    </Window.Background>
    <Grid Margin="20">

        <Border Background="#F5E6C8"
                CornerRadius="15"
                Padding="25"
                BorderBrush="#C9B27D"
                BorderThickness="2">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- TÍTULO -->
                <TextBlock Text="Termos de Uso"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#1F3A5F"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <!-- TEXTO -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto">
                    <ScrollViewer.Resources>

                        <Style TargetType="ScrollBar">
                            <Setter Property="Width" Value="10"/>
                            <Setter Property="Background" Value="#E8D7B0"/>
                        </Style>

                        <Style TargetType="Thumb">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Thumb">
                                        <Border Background="#C9B27D"
        BorderBrush="#1F3A5F"
        BorderThickness="1"
        CornerRadius="5"/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>

                    </ScrollViewer.Resources>

                    <TextBlock TextWrapping="Wrap"
                               FontSize="14"
                               Foreground="#2B2B2B"
                               LineHeight="24">

                        Bem-vindo à plataforma da Academia de Letras, Artes e História de Cruzeiro.
 <LineBreak/> <LineBreak/>
                        Ao utilizar este sistema, o usuário concorda em:
 <LineBreak/>
                        • Utilizar a plataforma de maneira respeitosa e adequada;
 <LineBreak/>
                        • Não publicar conteúdos ofensivos, ilegais ou impróprios;
 <LineBreak/>
                        • Respeitar os demais usuários da comunidade;
 <LineBreak/>
                        • Entender que todas as publicações podem passar por aprovação administrativa;
 <LineBreak/>
                        • Manter a segurança da própria conta e senha.
 <LineBreak/> <LineBreak/>
                        A administração poderá remover conteúdos ou restringir usuários que violem as regras da plataforma.
 <LineBreak/>
                        O uso contínuo do sistema implica concordância com estes termos.
                    </TextBlock>
                </ScrollViewer>

                <!-- BOTÃO -->
                <Button Grid.Row="2"
                        Content="Fechar"
                        Width="120"
                        Height="38"
                        Margin="0,20,0,0"
                        HorizontalAlignment="Center"
                        Background="#1F3A5F"
                        Foreground="Gold"
                        FontWeight="Bold"
                        BorderBrush="#C9B27D"
                        BorderThickness="2"
                        Click="Fechar_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>