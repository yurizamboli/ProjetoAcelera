<Window x:Class="ProjetoAcelera.Views.LoginRegistro.TelaLoginRegistro"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login e Cadastro"
        Height="550" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#0B2A3A">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="120"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Center" 
                    Margin="0,10,0,0" 
                    Width="148" Height="105">

            <Image Source="/ImagemAcelera/LogoALAHC.png"
                   Width="123"
                   Height="113"
                   Margin="0,0,0,10"/>
        </StackPanel>


        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>



            <!-- ================= CADASTRO ================= -->
            <Border Grid.Column="0"
                Height="310"
                Background="#F5E6C8"
                CornerRadius="15"
                VerticalAlignment="Top"
                Padding="20"
                Margin="0,15,0,0">
                <StackPanel Grid.Column="0"                            
                        Margin="20,-10,20,-10">

                    <TextBlock Text="Cadastro"
                           FontSize="24"
                           FontWeight="Bold"
                           TextAlignment="Center"
                           Foreground="#1F3A5F"
                           Margin="0,0,0,15"/>

                    <Border Background="#EAEAEA" 
                        CornerRadius="5" 
                        Margin="0,5">

                        <TextBox x:Name="txtNomeRegistro"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="10"
                             FontSize="14"
                             Text="Nome"
                             Foreground="Gray"
                             VerticalContentAlignment="Center"
                             GotFocus="TxtNomeRegistro_GotFocus"
                             LostFocus="TxtNomeRegistro_LostFocus" TextChanged="txtNomeRegistro_TextChanged"/>
                    </Border>

                    <Border Background="#EAEAEA" 
                        CornerRadius="5" 
                        Margin="0,5">

                        <TextBox x:Name="txtEmailRegistro"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="10"
                             FontSize="14"
                             Text="Email"
                             Foreground="Gray"
                             VerticalContentAlignment="Center"
                             GotFocus="TxtEmailRegistro_GotFocus"
                             LostFocus="TxtEmailRegistro_LostFocus" 
                             TextChanged="txtEmailRegistro_TextChanged"/>
                    </Border>

                    <Border Background="#EAEAEA" 
                        CornerRadius="5" 
                        Margin="0,5">
                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="35" />
                            </Grid.ColumnDefinitions>
                            <PasswordBox x:Name="txtSenhaRegistro"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="10"
                                     FontSize="14"
                                     VerticalContentAlignment="Center"
                                     GotFocus="TxtSenhaRegistro_GotFocus"
                                     LostFocus="TxtSenhaRegistro_LostFocus"
                                     PasswordChanged="txtSenhaRegistro_PasswordChanged"
                                     Grid.Column="0"
                                     HorizontalAlignment="Stretch"/>

                            <TextBox x:Name="txtSenhaVisivelRegistro"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="10"
                                 FontSize="14"
                                 VerticalContentAlignment="Center"
                                 Visibility="Collapsed"
                                 TextChanged="txtSenhaVisivelRegistro_TextChanged"
                                 Grid.Column="0"
                                 HorizontalAlignment="Stretch"/>

                            <Button Content="👁"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="BtnToggleSenha_ClickRegistro"
                                Grid.Column="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>

                            <TextBlock x:Name="txtSenhaPlaceholderRegistro"
                                   Text="Senha"
                                   Foreground="Gray"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"
                                   Grid.ColumnSpan="2"/>
                        </Grid>
                    </Border>

                    <Button Content="CADASTRAR"
                        Height="40"
                        Margin="0,15,0,5"
                        Background="#1F3A5F"
                        Foreground="#D4AF37"
                        FontWeight="Bold"
                        BorderBrush="#C9B27D"
                        BorderThickness="2"
                        Cursor="Hand"
                        Click="BtnCadastrar_Click"/>

                </StackPanel>
            </Border>

            <!-- ================= LOGIN ================= -->
            <Border Height="310"
                Background="#F5E6C8"
                CornerRadius="15"
                VerticalAlignment="Top"
                Padding="20" 
                Margin="0,15,10,0" 
                Grid.Column="2"/>

            <StackPanel Grid.Column="2"
                        Margin="20,35,25,94">

                <TextBlock Text="Login"
                            FontSize="22"
                            FontWeight="Bold"
                           TextAlignment="Center"
                            Margin="0,0,0,15"
                            Foreground="#1F3A5F"/>

                <TextBox x:Name="txtEmailLogin"
                            Height="40"
                            Margin="0,5"
                            Padding="8"
                            Background="#EDEDED"
                            BorderThickness="0"
                            FontSize="14"
                            VerticalContentAlignment="Center"
                            Text="Usuário"
                            Foreground="Gray"
                            GotFocus="TxtEmailLogin_GotFocus"
                            LostFocus="TxtEmailLogin_LostFocus" 
                            TextChanged="txtEmailLogin_TextChanged"/>

                <Border Background="#EAEAEA" CornerRadius="5" Margin="0,5">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="35" />
                        </Grid.ColumnDefinitions>

                        <PasswordBox x:Name="txtSenhaLogin"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="10"
                                     FontSize="14"
                                     VerticalContentAlignment="Center"
                                     GotFocus="TxtSenhaLogin_GotFocus"
                                     LostFocus="TxtSenhaLogin_LostFocus" 
                                     PasswordChanged="txtSenhaLogin_PasswordChanged"
                                     Grid.Column="0"/>

                        <TextBox x:Name="txtSenhaVisivelLogin"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="10"
                                 FontSize="14"
                                 VerticalContentAlignment="Center"
                                 Visibility="Collapsed"
                                 TextChanged="txtSenhaVisivelLogin_TextChanged"
                                 Grid.Column="0"/>

                        <Button Content="👁"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="BtnToggleSenha_ClickLogin"
                                Grid.Column="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>

                        <TextBlock x:Name="txtSenhaPlaceholderLogin"
                                   Text="Senha"
                                   Foreground="Gray"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"
                                   Grid.ColumnSpan="2"/>
                    </Grid>
                </Border>
                <Button Content="ENTRAR!"
                        Height="40"
                        Margin="0,15,0,0"
                        Background="#1F3A5F"
                        Foreground="Gold"
                        FontWeight="Bold"
                        BorderBrush="#C9B27D"
                        BorderThickness="2"
                        Cursor="Hand"
                        Click="BtnLogin_Click"/>

                <Button Content="Esqueceu a senha?"
					    Height="40"
					    Margin="0,15,0,0"
					    Background="#1F3A5F"
					    Foreground="Gold"
					    FontWeight="Bold"
					    BorderThickness="0"
					    Cursor="Hand"
					    Click="BtnEsqueceuSenha_Click"/>

            </StackPanel>

        </Grid>
    </Grid>
</Window>