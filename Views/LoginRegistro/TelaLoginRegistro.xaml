<Page x:Class="ProjetoAcelera.Views.LoginRegistro.TelaLoginRegistro"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Height="550"
      Width="1000"
      Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="120"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- LOGO -->
        <StackPanel Grid.Row="0"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Center"
                    Margin="0,10,0,0"
                    Width="148"
                    Height="105">

            <Image Source="/ImagemAcelera/LogoALAHC.png"
                   Width="123"
                   Height="113"
                   Margin="0,0,0,10"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="30,10,30,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="45"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <!-- ================= CADASTRO ================= -->
            <Border Grid.Column="0"
                    Background="#F5E6C8"
                    CornerRadius="18"
                    Padding="28"
                    BorderBrush="#C9B27D"
                    BorderThickness="2">

                <StackPanel>

                    <TextBlock Text="Cadastrar"
                               FontSize="26"
                               FontWeight="Bold"
                               TextAlignment="Center"
                               Foreground="#1F3A5F"
                               Margin="0,0,0,18"/>

                    <Border Background="#EAEAEA"
                            CornerRadius="8"
                            Margin="0,0,0,10">

                        <TextBox x:Name="txtNomeRegistro"
                                 Height="38"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="10"
                                 FontSize="14"
                                 Text="Nome"
                                 Foreground="Gray"
                                 VerticalContentAlignment="Center"
                                 GotFocus="TxtNomeRegistro_GotFocus"
                                 LostFocus="TxtNomeRegistro_LostFocus"
                                 TextChanged="txtNomeRegistro_TextChanged"/>
                    </Border>

                    <Border Background="#EAEAEA"
                            CornerRadius="8"
                            Margin="0,0,0,10">

                        <TextBox x:Name="txtEmailRegistro"
                                 Height="38"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="10"
                                 FontSize="14"
                                 Text="Email"
                                 Foreground="Gray"
                                 VerticalContentAlignment="Center"
                                 GotFocus="TxtEmailRegistro_GotFocus"
                                 LostFocus="TxtEmailRegistro_LostFocus"
                                 TextChanged="txtEmailRegistro_TextChanged"/>
                    </Border>

                    <Border Background="#EAEAEA"
                            CornerRadius="8"
                            Margin="0,0,0,8">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>

                            <PasswordBox x:Name="txtSenhaRegistro"
                                         Height="38"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="10"
                                         FontSize="14"
                                         VerticalContentAlignment="Center"
                                         GotFocus="TxtSenhaRegistro_GotFocus"
                                         LostFocus="TxtSenhaRegistro_LostFocus"
                                         PasswordChanged="txtSenhaRegistro_PasswordChanged"
                                         Grid.Column="0"/>

                            <TextBox x:Name="txtSenhaVisivelRegistro"
                                     Height="38"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="10"
                                     FontSize="14"
                                     VerticalContentAlignment="Center"
                                     Visibility="Collapsed"
                                     TextChanged="txtSenhaVisivelRegistro_TextChanged"
                                     Grid.Column="0"/>

                            <Button Content="👁"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="BtnToggleSenha_ClickRegistro"
                                    Grid.Column="1"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>

                            <TextBlock x:Name="txtSenhaPlaceholderRegistro"
                                       Text="Senha"
                                       Foreground="Gray"
                                       Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"
                                       Grid.ColumnSpan="2"/>
                        </Grid>
                    </Border>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,2,0,0">

                        <Button BorderThickness="0"
                                Background="Transparent"
                                Cursor="Hand"
                                Padding="5" Click="Button_Click">

                            <TextBlock Text="Termos de Uso"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Foreground="#1F3A5F"
                                       TextDecorations="Underline"/>
                        </Button>

                        <Button BorderThickness="0"
                                Background="Transparent"
                                Cursor="Hand"
                                Padding="5" Click="Button_Click_1">

                            <TextBlock Text="Política de Privacidade"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Foreground="#1F3A5F"
                                       TextDecorations="Underline"/>
                        </Button>
                    </StackPanel>

                    <CheckBox x:Name="chkTermos"
                              Margin="0,3,0,0"
                              HorizontalAlignment="Center"
                              Foreground="#1F3A5F">

                        <TextBlock Text="Li e concordo com os termos de uso e a Política de Privacidade"
                                   TextWrapping="Wrap"
                                   Width="285"
                                   FontSize="12"
                                   FontWeight="DemiBold"/>
                    </CheckBox>

                    <Button Content="CADASTRAR"
                            Height="40"
                            Margin="0,14,0,0"
                            Background="#1F3A5F"
                            Foreground="#D4AF37"
                            FontWeight="Bold"
                            BorderBrush="#C9B27D"
                            BorderThickness="2"
                            Cursor="Hand"
                            Click="BtnCadastrar_Click"/>
                </StackPanel>
            </Border>

            <!-- ================= LOGIN ================= -->
            <Border Grid.Column="2"
                    Background="#F5E6C8"
                    CornerRadius="18"
                    Padding="28"
                    BorderBrush="#C9B27D"
                    BorderThickness="2">

                <StackPanel>

                    <TextBlock Text="Entrar"
                               FontSize="26"
                               FontWeight="Bold"
                               TextAlignment="Center"
                               Foreground="#1F3A5F"
                               Margin="0,0,0,25"/>

                    <Border Background="#EAEAEA"
                            CornerRadius="8"
                            Margin="0,0,0,12">

                        <TextBox x:Name="txtEmailLogin"
                                 Height="40"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="10"
                                 FontSize="14"
                                 Text="Usuário"
                                 Foreground="Gray"
                                 VerticalContentAlignment="Center"
                                 GotFocus="TxtEmailLogin_GotFocus"
                                 LostFocus="TxtEmailLogin_LostFocus"
                                 TextChanged="txtEmailLogin_TextChanged"/>
                    </Border>

                    <Border Background="#EAEAEA"
                            CornerRadius="8"
                            Margin="0,0,0,20">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>

                            <PasswordBox x:Name="txtSenhaLogin"
                                         Height="40"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="10"
                                         FontSize="14"
                                         VerticalContentAlignment="Center"
                                         GotFocus="TxtSenhaLogin_GotFocus"
                                         LostFocus="TxtSenhaLogin_LostFocus"
                                         PasswordChanged="txtSenhaLogin_PasswordChanged"
                                         Grid.Column="0"/>

                            <TextBox x:Name="txtSenhaVisivelLogin"
                                     Height="40"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="10"
                                     FontSize="14"
                                     VerticalContentAlignment="Center"
                                     Visibility="Collapsed"
                                     TextChanged="txtSenhaVisivelLogin_TextChanged"
                                     Grid.Column="0"/>

                            <Button Content="👁"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="BtnToggleSenha_ClickLogin"
                                    Grid.Column="1"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>

                            <TextBlock x:Name="txtSenhaPlaceholderLogin"
                                       Text="Senha"
                                       Foreground="Gray"
                                       Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"
                                       Grid.ColumnSpan="2"/>
                        </Grid>
                    </Border>

                    <Button Content="ENTRAR!"
                            Height="42"
                            Margin="0,0,0,14"
                            Background="#1F3A5F"
                            Foreground="Gold"
                            FontWeight="Bold"
                            BorderBrush="#C9B27D"
                            BorderThickness="2"
                            Cursor="Hand"
                            Click="BtnLogin_Click"/>

                    <Button Content="Esqueceu a senha?"
                            Height="38"
                            Background="Transparent"
                            Foreground="#1F3A5F"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="BtnEsqueceuSenha_Click"/>
                </StackPanel>
            </Border>

        </Grid>
    </Grid>
</Page>