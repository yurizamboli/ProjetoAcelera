<Window x:Class="ProjetoAcelera.Views.EditarObras.TelaEditarObra"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Adicionar Obra"
        Height="Auto" Width="400"
        WindowStartupLocation="CenterScreen"
        Background="#0A2A3A">

    <Grid>

        <Border Background="#F3E6C9"
                Margin="20"
                Padding="20"
                CornerRadius="10">

            <StackPanel>

                <TextBlock Text="Editar Obra"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="0,0,0,15"
                           Foreground="#1F3A5F"/>
            <!-- Título -->
                <Grid Margin="0,5">
    <TextBox x:Name="txtTitulo"
             Height="35"
             Background="#EAEAEA"
             BorderThickness="0"
             Padding="10"
             VerticalContentAlignment="Center"
             GotFocus="TxtTitulo_GotFocus"
             LostFocus="TxtTitulo_LostFocus" TextChanged="txtTitulo_TextChanged"/>

    <TextBlock x:Name="txtTituloPlaceholder"           
               Foreground="Gray"
               Margin="12,0,0,0"
               VerticalAlignment="Center"
               IsHitTestVisible="False"/>
</Grid>

<!-- Descrição -->
                <Grid Margin="0,5">
    <TextBox x:Name="txtDescricao"
             Height="80"
             AcceptsReturn="True"
             TextWrapping="Wrap"
             Background="#EAEAEA"
             BorderThickness="0"
             Padding="10"
             GotFocus="TxtDescricao_GotFocus"
             LostFocus="TxtDescricao_LostFocus" TextChanged="txtDescricao_TextChanged"/>

    <TextBlock x:Name="txtDescricaoPlaceholder"
               Foreground="Gray"
               Margin="12,10,0,0"
               VerticalAlignment="Top"
               IsHitTestVisible="False"/>
</Grid>
            <Border Height="150"
        Background="#EAEAEA"
        Margin="0,5"
        CornerRadius="10">

    <Image x:Name="imgPreview"
           Stretch="UniformToFill"/>
</Border>

<Button Content="Selecionar Imagem"
        Height="30"
        Margin="0,5"
        Background="#1F3A5F"
        Foreground="Gold"
        Click="BtnSelecionarImagem_Click"/>

                <Button Content="Salvar"
                        Height="35"
                        Margin="0,10,0,0"
                        Background="#1F3A5F"
                        Foreground="Gold"
                        Click="BtnSalvar_Click"/>

            </StackPanel>

        </Border>

    </Grid>
</Window>