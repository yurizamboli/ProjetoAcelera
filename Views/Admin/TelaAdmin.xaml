<Window x:Class="ProjetoAcelera.Views.Admin.TelaAdmin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Admin"
        Height="800" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#0A2A3A">

    <Grid>

        <Border Background="#F3E6C9"
                CornerRadius="15"
                Margin="30"
                Padding="20">

            <StackPanel>

                <!-- PERFIL -->
                <StackPanel Orientation="Horizontal">

                    <!-- FOTO -->
                    <Border Width="140" Height="140"
                            CornerRadius="10"
                            ClipToBounds="True"
                            BorderBrush="#1F3A5F"
                            BorderThickness="2">

                        <Image x:Name="imgPerfil"
                               Stretch="UniformToFill"/>
                    </Border>

                    <!-- INFO -->
                    <StackPanel Margin="15,0" Width="500">

                        <TextBlock x:Name="txtNome"
                                   Background="#EAEAEA"
                                   Padding="10"
                                   Margin="0,0,0,10"/>

                        <TextBlock x:Name="txtBio"
                                   Background="#EAEAEA"
                                   Padding="10"
                                   TextWrapping="Wrap"
                                   Height="70"/>
                    </StackPanel>

                    <!-- BOTÃO -->
                    <StackPanel Margin="10,0">
                        <Button Content="Voltar"
                                Click="Voltar_Click"/>
                    </StackPanel>

                </StackPanel>

                <!-- EVENTO -->
                <Border Background="#D3D3D3" Margin="0,20" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Criar Evento" FontWeight="Bold"/>

                        <TextBox x:Name="txtTituloEvento" Margin="0,5"/>
                        <TextBox x:Name="txtDescEvento" Margin="0,5"/>
                        <DatePicker x:Name="dateEvento" Margin="0,5"/>

                        <Button Content="Adicionar Evento"
                                Click="AdicionarEvento_Click"
                                Margin="0,10"/>
                    </StackPanel>
                </Border>

                <!-- DESTAQUE -->
                <Border Background="#D3D3D3" Margin="0,10" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Destacar Usuário" FontWeight="Bold"/>

                        <ComboBox x:Name="comboUsuarios" Margin="0,5"/>

                        <Button Content="Colocar em destaque"
                                Click="Destaque_Click"/>
                    </StackPanel>
                </Border>

                <!-- PROMOVER -->
                <Border Background="#D3D3D3" Margin="0,10" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Promover para Admin" FontWeight="Bold"/>

                        <ComboBox x:Name="comboPromover" Margin="0,5"/>

                        <Button Content="Promover"
                                Background="Green"
                                Foreground="White"
                                Click="Promover_Click"/>
                    </StackPanel>
                </Border>

                <!-- REMOVER -->
                <Border Background="#D3D3D3" Margin="0,10" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Remover Usuário" FontWeight="Bold"/>

                        <ComboBox x:Name="comboRemover"
                                  Margin="0,5"/>

                        <Button Content="Remover"
                                Background="DarkRed"
                                Foreground="White"
                                Click="Remover_Click"/>
                    </StackPanel>
                </Border>

            </StackPanel>

        </Border>

    </Grid>
</Window>