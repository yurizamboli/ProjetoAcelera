<Page x:Class="ProjetoAcelera.Views.Admin.TelaAdmin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Page.Background>
        <ImageBrush ImageSource="/ImagemAcelera/solid-navy-blue-concrete-textured-wall.jpg"
                Stretch="UniformToFill"/>
    </Page.Background>
    <Grid>
        
        <ScrollViewer VerticalScrollBarVisibility="Hidden"
                        HorizontalScrollBarVisibility="Disabled" >

            <Border Background="#F3E6C9"
                CornerRadius="15"
                Margin="5,15,5,30"
                Padding="20"
                MinWidth="1000"
                MaxWidth="1076">

                <StackPanel Margin="0,0,0,40">

                    <!-- PERFIL -->
                    <StackPanel Orientation="Horizontal">

                        <!-- FOTO -->
                        <Border Width="140" Height="140"
                            CornerRadius="10"
                            ClipToBounds="True"
                            BorderBrush="#1F3A5F"
                            BorderThickness="2">

                            <Image x:Name="imgPerfil"
                               Stretch="UniformToFill"/>
                        </Border>

                        <!-- INFO -->
                        <StackPanel Margin="15,0" Width="500">

                            <TextBlock x:Name="txtNome"
                                   Background="#EAEAEA"
                                   Padding="10"
                                   Margin="0,0,0,10"/>

                            <TextBlock x:Name="txtBio"
                                   Background="#EAEAEA"
                                   Padding="10"
                                   TextWrapping="Wrap"
                                   Height="70"/>
                        </StackPanel>

                        <!-- BOTÕES -->
                        <StackPanel Margin="10,0"
            VerticalAlignment="Top">

                            <Button Content="Voltar"
            Height="32"
            Margin="0,0,0,8"
            Background="#1F3A5F"
            Foreground="Gold"
            FontWeight="Bold"
            BorderThickness="0"
            Click="Voltar_Click" Width="72"/>

                            <Button Content="Sair"
            Height="32"
            Background="#1F3A5F"
            Foreground="Gold"
            FontWeight="Bold"
            BorderThickness="0"
            Click="Logout_Click"/>

                        </StackPanel>

                    </StackPanel>

                    <!-- EVENTO -->
                    <Border Background="#D3D3D3" Margin="0,20" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Criar Evento" FontWeight="Bold"/>

                            <TextBox x:Name="txtTituloEvento" Margin="0,5"/>
                            <TextBox x:Name="txtDescEvento" Margin="0,5" Height="60" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                            <DatePicker x:Name="dateEvento" Margin="0,5"/>
                            
                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                <Button Content="Selecionar Imagem" Click="SelecionarImagemEvento_Click" Padding="8,4" Margin="0,0,8,0"/>
                                <TextBox x:Name="txtCaminhoImagem" Text="Selecione uma imagem..." IsReadOnly="True" Foreground="#666666"/>
                            </StackPanel>

                            <Button Content="Adicionar Evento"
                                Click="AdicionarEvento_Click"
                                Margin="0,10"/>
                        </StackPanel>
                    </Border>

                    <!-- GERENCIAR EVENTOS -->
                    <Border Background="#D3D3D3" Margin="0,10" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Gerenciar Eventos" FontWeight="Bold"/>

                            <ListBox x:Name="listaEventos" Margin="0,5,0,0" Height="150" SelectionMode="Single"/>
                            
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <Button Content="Editar" Click="EditarEvento_Click" Padding="8,4" Margin="0,0,8,0"/>
                                <Button Content="Deletar" Click="DeletarEvento_Click" Padding="8,4" Background="#C0392B" Foreground="White"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- PROGRAMAÇÃO -->
                    <Border Background="#D3D3D3" Margin="0,10" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Adicionar Programação ao Evento" FontWeight="Bold"/>

                            <ComboBox x:Name="comboEventosProgramacao" Margin="0,5"/>
                            <DatePicker x:Name="dateProgramacao" Margin="0,5"/>
                            <TextBox x:Name="txtNomeProgramacao" Margin="0,5"/>
                            <TextBox x:Name="txtDescProgramacao" Margin="0,5" Height="60" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>

                            <Button Content="Adicionar Programação"
                                Click="AdicionarProgramacao_Click"
                                Margin="0,10"/>
                        </StackPanel>
                    </Border>

					<!-- DESTAQUE -->
					<Border Background="#D3D3D3" Margin="0,10" Padding="10">
						<StackPanel>

							<TextBlock Text="Destacar Usuário"
									   FontWeight="Bold"/>

							<ComboBox x:Name="comboUsuarios"
									  Margin="0,5"/>

							<Button Content="Colocar em destaque"
									Click="Destaque_Click"
									Margin="0,0,0,12"/>
							<TextBlock Text="Artistas em destaque"
									   FontWeight="Bold"
									   Margin="0,10,0,5"/>

							<ListBox x:Name="listaDestaques"
									 Height="180">
								
								<ListBox.ItemTemplate>
									<DataTemplate>
										<Border Background="#F3E6C9"
												BorderBrush="#1F3A5F"
												BorderThickness="1"
												Padding="8"
												Margin="0,0,0,8">
											<Grid>
												<Grid.ColumnDefinitions>
													<ColumnDefinition Width="*"/>
													<ColumnDefinition Width="Auto"/>
												</Grid.ColumnDefinitions>
												<TextBlock Text="{Binding Nome}"
														   VerticalAlignment="Center"
														   FontWeight="Bold"/>
												
												<Button Grid.Column="1"
														Content="Remover"
														Background="#C0392B"
														Foreground="White"
														Padding="8,4"
														Tag="{Binding}"
														Click="RemoverDestaque_Click"/>
											</Grid>
										</Border>
									</DataTemplate>
								</ListBox.ItemTemplate>
							</ListBox>
						</StackPanel>
					</Border>
					<!-- PROMOVER -->
					<Border Background="#D3D3D3" Margin="0,10" Padding="10">
						<StackPanel>

							<TextBlock Text="Promover para Admin"
									   FontWeight="Bold"/>

							<ComboBox x:Name="comboPromover"
									  Margin="0,5"/>

							<Button Content="Promover"
									Background="Green"
									Foreground="White"
									Click="Promover_Click"/>
						</StackPanel>
					</Border>
                    <!-- Banir -->
                    <Border Background="#D3D3D3" Margin="0,10" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Banir Usuário" FontWeight="Bold"/>

                            <ComboBox x:Name="comboBanir"
                                  Margin="0,5"/>

                            <Button Content="Banir"
                                Background="DarkRed"
                                Foreground="White"
                                Click="Banir_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Postagens pendentes -->
                    <Border Background="#D3D3D3" Margin="0,10" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Postagens pendentes" FontWeight="Bold"/>
                            <ListView x:Name="listaPostagensPendentes" Margin="0,10,0,0" Height="420" SelectionMode="Single" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment"
                                                 Value="Stretch"/>

                                        <Setter Property="Padding"
                                                 Value="0"/>

                                        <Setter Property="Margin"
                                                Value="0,0,0,10"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#F8F1DF" BorderBrush="#1F3A5F" BorderThickness="2" MaxWidth="950" Height="410" CornerRadius="12" Padding="12" Margin="0,0,0,15" HorizontalAlignment="Stretch">
                                            <StackPanel>
                                                <TextBlock Text="{Binding NomeAutor}" FontWeight="Bold"/>
                                                <ScrollViewer MaxHeight="100"
                                                              VerticalScrollBarVisibility="Auto"
                                                              HorizontalScrollBarVisibility="Disabled"
                                                              Margin="0,6,0,0">

                                                    <TextBlock Text="{Binding Conteudo}"
                                                               TextWrapping="Wrap"/>

                                                </ScrollViewer>
                                                <Border CornerRadius="10"
                                                    Margin="0,10,0,0"
                                                    ClipToBounds="True"
                                                    BorderBrush="#C9B27D"
                                                    BorderThickness="1">

                                                    <Image Source="{Binding ImagemUrl}"
                                                           MaxHeight="180"                                                          
                                                           Stretch="UniformToFill"
                                                           Cursor="Hand"
                                                           MouseDown="AbrirImagem_Click"/>
                                                </Border>
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                    <TextBlock Text="Vídeo: " FontWeight="Bold"/>
                                                    <TextBlock Text="{Binding CaminhoVideo}" TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                                                    <Button Content="Aprovar" Padding="8,4" Margin="0,0,8,0" Click="AprovarPostagem_Click" Tag="{Binding}"/>
                                                    <Button Content="Reprovar" Padding="8,4" Background="#C0392B" Foreground="White" Click="ReprovarPostagem_Click" Tag="{Binding}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                </StackPanel>

            </Border>
        </ScrollViewer>
    </Grid>
</Page>