<Page x:Class="ProjetoAcelera.Views.Admin.ContainerPainelAdmin"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">
    <Page.Resources>

        <!-- BOTÃO PADRÃO AZUL -->
        <Style x:Key="BotaoAzul" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="14,5"/>
            <Setter Property="Background" Value="#1F3A5F"/>
            <Setter Property="Foreground" Value="#F3E6C9"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,6,8,0"/>
        </Style>

        <!-- BOTÃO DOURADO -->
        <Style x:Key="BotaoDourado" TargetType="Button" BasedOn="{StaticResource BotaoAzul}">
            <Setter Property="Background" Value="#B8860B"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- BOTÃO VERMELHO -->
        <Style x:Key="BotaoVermelho" TargetType="Button" BasedOn="{StaticResource BotaoAzul}">
            <Setter Property="Background" Value="#8B1E1E"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- TEXTBOX PADRÃO -->
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Setter Property="Background" Value="#FFF7E1"/>
            <Setter Property="Foreground" Value="#1F3A5F"/>
            <Setter Property="BorderBrush" Value="#C9B27D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- COMBOBOX PADRÃO -->
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Setter Property="Background" Value="#FFF7E1"/>
            <Setter Property="Foreground" Value="#1F3A5F"/>
            <Setter Property="BorderBrush" Value="#C9B27D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="8,2"/>
        </Style>

        <!-- DATEPICKER PADRÃO -->
        <Style TargetType="DatePicker">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Setter Property="Background" Value="#FFF7E1"/>
            <Setter Property="Foreground" Value="#1F3A5F"/>
            <Setter Property="BorderBrush" Value="#C9B27D"/>
        </Style>

        <!-- TÍTULO DOS CARDS -->
        <Style x:Key="TituloCard" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#1F3A5F"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- SUBTÍTULO -->
        <Style x:Key="Subtitulo" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="Margin" Value="0,-6,0,10"/>
        </Style>

    </Page.Resources>

    <Grid Background="Transparent">

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <StackPanel Margin="5">

                <TextBlock Text="Painel Administrativo"
                               FontSize="30"
                               FontWeight="Bold"
                               FontFamily="Georgia"
                               Foreground="#1F3A5F"
                               HorizontalAlignment="Left"
                               Margin="0,0,0,22"/>

                <!-- EVENTOS E PROGRAMAÇÃO -->
                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- CRIAR EVENTO -->
                    <Border Grid.Column="0"
                                Background="#FFF7E1"
                                BorderBrush="#C9B27D"
                                BorderThickness="2"
                                CornerRadius="18"
                                Padding="16"
                                Margin="0,0,10,0">

                        <StackPanel>

                            <TextBlock Text="Criar Evento"
                                           Style="{StaticResource TituloCard}"/>

                            <TextBlock Text="Cadastre um novo evento cultural para exibição no sistema."
                                           Style="{StaticResource Subtitulo}"/>

                            <TextBox x:Name="txtTituloEvento"
                                         ToolTip="Título do evento"/>

                            <TextBox x:Name="txtDescEvento"
                                         Height="80"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         ToolTip="Descrição do evento"/>

                            <DatePicker x:Name="dateEvento"/>

                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button Content="Selecionar Imagem"
                                            Style="{StaticResource BotaoAzul}"
                                            Click="SelecionarImagemEvento_Click"/>

                                <TextBox x:Name="txtCaminhoImagem"
                                             Grid.Column="1"
                                             Text="Selecione uma imagem..."
                                             IsReadOnly="True"
                                             Foreground="#666666"/>
                            </Grid>

                            <Button Content="Adicionar Evento"
                                        Style="{StaticResource BotaoDourado}"
                                        Width="180"
                                        HorizontalAlignment="Right"
                                        Click="AdicionarEvento_Click"/>

                        </StackPanel>
                    </Border>

                    <!-- PROGRAMAÇÃO -->
                    <Border Grid.Column="1"
                                Background="#FFF7E1"
                                BorderBrush="#C9B27D"
                                BorderThickness="2"
                                CornerRadius="18"
                                Padding="16"
                                Margin="10,0,0,0">

                        <StackPanel>

                            <TextBlock Text="Adicionar Programação"
                                           Style="{StaticResource TituloCard}"/>

                            <TextBlock Text="Vincule uma atividade ou programação a um evento já cadastrado."
                                           Style="{StaticResource Subtitulo}"/>

                            <ComboBox x:Name="comboEventosProgramacao"/>

                            <DatePicker x:Name="dateProgramacao"/>

                            <TextBox x:Name="txtNomeProgramacao"
                                         ToolTip="Nome da programação"/>

                            <TextBox x:Name="txtDescProgramacao"
                                         Height="80"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         ToolTip="Descrição da programação"/>

                            <Button Content="Adicionar Programação"
                                        Style="{StaticResource BotaoDourado}"
                                        Width="210"
                                        HorizontalAlignment="Right"
                                        Click="AdicionarProgramacao_Click"/>

                        </StackPanel>
                    </Border>
                </Grid>

                <!-- GERENCIAR EVENTOS -->
                <Border Background="#FFF7E1"
                            BorderBrush="#C9B27D"
                            BorderThickness="2"
                            CornerRadius="18"
                            Padding="16"
                            Margin="0,0,0,18">

                    <StackPanel>
                        <TextBlock Text="Gerenciar Eventos"
                                       Style="{StaticResource TituloCard}"/>

                        <TextBlock Text="Edite ou remova eventos cadastrados."
                                       Style="{StaticResource Subtitulo}"/>

                        <ListBox x:Name="listaEventos"
                                     Margin="0,8,0,0"
                                     Height="160"
                                     SelectionMode="Single"
                                     Background="#F3E6C9"
                                     BorderBrush="#C9B27D"/>

                        <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Margin="0,8,0,0">

                            <Button Content="Editar"
                                        Width="100"
                                        Style="{StaticResource BotaoAzul}"
                                        Click="EditarEvento_Click"/>

                            <Button Content="Deletar"
                                        Width="100"
                                        Style="{StaticResource BotaoVermelho}"
                                        Click="DeletarEvento_Click"/>

                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- USUÁRIOS -->
                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- DESTAQUE -->
                    <Border Grid.Column="0"
                                Background="#FFF7E1"
                                BorderBrush="#C9B27D"
                                BorderThickness="2"
                                CornerRadius="18"
                                Padding="16"
                                Margin="0,0,10,0">

                        <StackPanel>
                            <TextBlock Text="Destacar Usuário"
                                           Style="{StaticResource TituloCard}"/>

                            <TextBlock Text="Escolha artistas para aparecerem em destaque na Home."
                                           Style="{StaticResource Subtitulo}"/>

                            <ComboBox x:Name="comboUsuarios"/>

                            <Button Content="Colocar em destaque"
                                        Style="{StaticResource BotaoDourado}"
                                        HorizontalAlignment="Right"
                                        Click="Destaque_Click"/>

                            <TextBlock Text="Artistas em destaque"
                                           FontWeight="Bold"
                                           Foreground="#1F3A5F"
                                           Margin="0,14,0,6"/>

                            <ListBox x:Name="listaDestaques"
                                         Height="180"
                                         Background="#F3E6C9"
                                         HorizontalContentAlignment="Stretch">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,0,0,6"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#FFF7E1"
                                                    BorderBrush="#1F3A5F"
                                                    BorderThickness="1"
                                                    Padding="8"
                                                    Height="45"
                                                    HorizontalAlignment="Stretch">

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="{Binding Nome}"
                                                            VerticalAlignment="Center"
                                                            FontWeight="Bold"
                                                            Foreground="#1F3A5F"
                                                            TextTrimming="CharacterEllipsis"
                                                            Margin="0,0,10,0"/>

                                                <Button Grid.Column="1"
                                                        Content="Remover"
                                                        Width="70"
                                                        Height="24"
                                                        Padding="4,1"
                                                        Margin="12,0,0,0"
                                                        Background="#8B1E1E"
                                                        Foreground="White"
                                                        FontSize="11"
                                                        FontWeight="Bold"
                                                        BorderThickness="0"
                                                        Cursor="Hand"
                                                        VerticalAlignment="Center"
                                                        Tag="{Binding}"
                                                        Click="RemoverDestaque_Click"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>

                    <!-- PROMOVER -->
                    <Border Grid.Column="1"
                                Background="#FFF7E1"
                                BorderBrush="#C9B27D"
                                BorderThickness="2"
                                CornerRadius="18"
                                Padding="16"
                                Margin="10,0,10,0">

                        <StackPanel>
                            <TextBlock Text="Promover para Admin"
                                           Style="{StaticResource TituloCard}"/>

                            <TextBlock Text="Transforme um usuário comum em administrador."
                                           Style="{StaticResource Subtitulo}"/>

                            <ComboBox x:Name="comboPromover"/>

                            <Button Content="Promover"
                                        Background="#2E7D32"
                                        Foreground="White"
                                        FontWeight="Bold"
                                        BorderThickness="0"
                                        Height="34"
                                        Cursor="Hand"
                                        Margin="0,10,0,0"
                                        Click="Promover_Click"/>
                            <TextBlock Text="Administradores promovidos"
                   FontWeight="Bold"
                   Foreground="#1F3A5F"
                   Margin="0,14,0,6"/>

                            <ListBox x:Name="listaAdmins"
                                     Height="180"
                                     Background="#F3E6C9"
                                     BorderBrush="#C9B27D"
                                     HorizontalContentAlignment="Stretch">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,0,0,6"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#FFF7E1"
                                                BorderBrush="#1F3A5F"
                                                BorderThickness="1"
                                                Padding="8"
                                                Height="45"
                                                HorizontalAlignment="Stretch">

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="{Binding Email}"
                                                           VerticalAlignment="Center"
                                                           FontWeight="Bold"
                                                           Foreground="#1F3A5F"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="0,0,10,0"/>

                                                <Button Grid.Column="1"
                                                        Content="Remover"
                                                        Width="70"
                                                        Height="24"
                                                        Padding="4,1"
                                                        Margin="12,0,0,0"
                                                        Background="#8B1E1E"
                                                        Foreground="White"
                                                        FontSize="11"
                                                        FontWeight="Bold"
                                                        BorderThickness="0"
                                                        Cursor="Hand"
                                                        VerticalAlignment="Center"
                                                        Tag="{Binding}"
                                                        Click="RemoverAdmin_Click"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                        
                    </Border>

                    <!-- BANIR -->
                    <!-- BANIR -->
                    <Border Grid.Column="2"
        Background="#FFF7E1"
        BorderBrush="#C9B27D"
        BorderThickness="2"
        CornerRadius="18"
        Padding="16"
        Margin="10,0,0,0">

                        <StackPanel>
                            <TextBlock Text="Banir Usuário"
                   Style="{StaticResource TituloCard}"/>

                            <TextBlock Text="Bloqueie usuários que não devem acessar o sistema."
                   Style="{StaticResource Subtitulo}"/>

                            <ComboBox x:Name="comboBanir"/>

                            <Button Content="Banir"
                                    Style="{StaticResource BotaoVermelho}"
                                    Margin="0,10,0,0"
                                    Click="Banir_Click"/>

                            <TextBlock Text="Usuários banidos"
                                       FontWeight="Bold"
                                       Foreground="#1F3A5F"
                                       Margin="0,14,0,6"/>

                            <ListBox x:Name="listaBanidos"
                                     Height="180"
                                     Background="#F3E6C9"
                                     BorderBrush="#C9B27D"
                                     HorizontalContentAlignment="Stretch">

                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,0,0,6"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>

                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#FFF7E1"
                                                BorderBrush="#1F3A5F"
                                                BorderThickness="1"
                                                Padding="8"
                                                Height="45"
                                                HorizontalAlignment="Stretch">

                                            <Grid HorizontalAlignment="Stretch">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                                            Text="{Binding Email}"
                                                            VerticalAlignment="Center"
                                                            FontWeight="Bold"
                                                            Foreground="#1F3A5F"
                                                            TextTrimming="CharacterEllipsis"
                                                            Margin="0,0,10,0"/>

                                                <Button Grid.Column="1"
                                                        Content="Liberar"
                                                        Width="65"
                                                        Height="24"
                                                        Padding="4,1"
                                                        Margin="12,0,0,0"
                                                        Background="#2E7D32"
                                                        Foreground="White"
                                                        FontSize="11"
                                                        FontWeight="Bold"
                                                        BorderThickness="0"
                                                        Cursor="Hand"
                                                        VerticalAlignment="Center"
                                                        Tag="{Binding}"
                                                        Click="RemoverBanimento_Click"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- POSTAGENS PENDENTES -->
                <Border Background="#FFF7E1"
                            BorderBrush="#C9B27D"
                            BorderThickness="2"
                            CornerRadius="18"
                            Padding="16"
                            Margin="0,0,0,20">

                    <StackPanel>
                        <TextBlock Text="Postagens Pendentes"
                                       Style="{StaticResource TituloCard}"/>

                        <TextBlock Text="Analise as publicações enviadas pelos usuários antes de liberar no feed global."
                                       Style="{StaticResource Subtitulo}"/>

                        <ListView x:Name="listaPostagensPendentes"
                                      Margin="0,10,0,0"
                                      Height="430"
                                      SelectionMode="Single"
                                      Background="#F3E6C9"
                                      BorderBrush="#C9B27D"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto">

                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,0,0,10"/>
                                </Style>
                            </ListView.ItemContainerStyle>

                            <ListView.ItemTemplate>
                                <DataTemplate>

                                    <Border Background="#FFF7E1"
                                                BorderBrush="#1F3A5F"
                                                BorderThickness="2"
                                                MaxWidth="930"
                                                Height="425"
                                                CornerRadius="14"
                                                Padding="12"
                                                Margin="0,0,0,15"
                                                HorizontalAlignment="Stretch">

                                        <Grid>

                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0"
                                                           Text="{Binding NomeAutor}"
                                                           FontWeight="Bold"
                                                           FontSize="15"
                                                           Foreground="#1F3A5F"/>

                                            <ScrollViewer Grid.Row="1"
                                                              MaxHeight="100"
                                                              VerticalScrollBarVisibility="Auto"
                                                              HorizontalScrollBarVisibility="Disabled"
                                                              Margin="0,8,0,0">

                                                <TextBlock Text="{Binding Conteudo}"
                                                               TextWrapping="Wrap"
                                                               Foreground="#333333"/>

                                            </ScrollViewer>

                                            <Border Grid.Row="2"
                                                        CornerRadius="12"
                                                        Margin="0,10,0,10"
                                                        ClipToBounds="True"
                                                        BorderBrush="#C9B27D"
                                                        BorderThickness="1"
                                                        Background="#E8E1CF">

                                                <Image Source="{Binding ImagemUrl}"
                                                           Height="200"
                                                           Stretch="UniformToFill"
                                                           Cursor="Hand"
                                                           MouseDown="AbrirImagem_Click"/>

                                            </Border>

                                            <Grid Grid.Row="3"
                                                      Margin="0,8,0,0"
                                                      VerticalAlignment="Bottom">

                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="Deseja publicar esta postagem no feed global?"
                                                               Foreground="#1F3A5F"
                                                               FontWeight="Bold"
                                                               VerticalAlignment="Center"/>

                                                <Button Grid.Column="1"
                                                            Content="Publicar na Home"
                                                            Width="145"
                                                            Height="34"
                                                            Margin="0,0,8,0"
                                                            Background="#B8860B"
                                                            Foreground="White"
                                                            FontWeight="Bold"
                                                            BorderThickness="0"
                                                            Cursor="Hand"
                                                            VerticalAlignment="Center"
                                                            Click="AprovarPostagem_Click"
                                                            Tag="{Binding}"/>

                                                <Button Grid.Column="2"
                                                            Content="Não publicar"
                                                            Width="125"
                                                            Height="34"
                                                            Background="#8B1E1E"
                                                            Foreground="White"
                                                            FontWeight="Bold"
                                                            BorderThickness="0"
                                                            Cursor="Hand"
                                                            VerticalAlignment="Center"
                                                            Click="ReprovarPostagem_Click"
                                                            Tag="{Binding}"/>

                                            </Grid>

                                        </Grid>
                                    </Border>

                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>