<Window x:Class="ProjetoAcelera.Views.Calendario.Calendario"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Calendário"
        Height="700" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#0A2A3A">
    <Grid Background="#0B2A3A">
        <!-- MENU SUPERIOR -->
        <StackPanel Background="#F3E6C9" Height="60" VerticalAlignment="Top">

            <!-- TÍTULO -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                <TextBlock Text="ACADEMIA DE LETRAS ARTES E HISTÓRIA DE CRUZEIRO"
                   FontWeight="Bold"
                   FontSize="16"
                   Foreground="#1F3A5F"/>
            </StackPanel>

            <!-- MENU -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                <TextBlock Text="Home" Margin="15,0"/>


                <!-- PROGRAMAÇÃO -->
                <TextBlock Text="Progamação"
                        Margin="15,0"
                        Foreground="Black"
                        FontWeight="Bold"/>
                <TextBlock Text="Cultura" Margin="15,0"/>

                <!--Botão Artistas -->
                <Button Content="Artistas"
            Margin="15,0"
            Background="Transparent"
            BorderThickness="0"
            Foreground="#1F3A5F"
            Cursor="Hand"
            Click="Artistas_Click"/>

                <Button Content="Nossa CIdade"
        Margin="15,0"
        Background="Transparent"
        BorderThickness="0"
        Foreground="#1F3A5F"
        Cursor="Hand"
        Click="NossaCidade_Click"
                        />

                <!-- BOTÃO CONTA -->
                <Button Content="Conta"
                Margin="15,0"
                Background="Transparent"
                BorderThickness="0"
                Foreground="#1F3A5F"
                Cursor="Hand"
                Click="Conta_Click"/>
            </StackPanel>

        </StackPanel>
        <TextBlock Text="PRÓXIMOS ENCONTROS"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="#B8860B"
                   HorizontalAlignment="Center"
                   FontFamily="Inter"
                   Margin="0,60,0,50"/>

        <Border Background="#EDE3D1"
                CornerRadius="15"
                Padding="25"
                Width="620"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,80,0,0">

            <StackPanel>

                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="btnAnterior"
                            Content="◀"
                            FontSize="18"
                            Width="40" Height="40"
                            Background="#B8860B"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="BtnAnterior_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="20">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <TextBlock x:Name="txtMes"
                               Grid.Column="1"
                               FontSize="22"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#2C3E50"/>

                    <Button x:Name="btnProximo"
                            Grid.Column="2"
                            Content="▶"
                            FontSize="18"
                            Width="40" Height="40"
                            Background="#B8860B"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="BtnProximo_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="20">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <UniformGrid Columns="7" Margin="0,0,0,10">
                    <TextBlock Text="Seg" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#2C3E50"/>
                    <TextBlock Text="Ter" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#2C3E50"/>
                    <TextBlock Text="Qua" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#2C3E50"/>
                    <TextBlock Text="Qui" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#2C3E50"/>
                    <TextBlock Text="Sex" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#2C3E50"/>
                    <TextBlock Text="Sáb" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#2C3E50"/>
                    <TextBlock Text="Dom" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#2C3E50"/>
                </UniformGrid>

                <Border BorderBrush="#B8860B"
                        BorderThickness="2"
                        Padding="10"
                        Background="White"
                        CornerRadius="8">
                    <UniformGrid x:Name="gridDias"
                                 Columns="7"
                                 Margin="0,5,0,0"/>
                </Border>

                <StackPanel Margin="0,25,0,0">

                    <TextBlock Text="FEIRA DO LIVRO:"
                               FontWeight="Bold"
                               FontSize="14"
                               Foreground="#B8860B"/>

                    <TextBlock Text="A feira do livro..."
                               Margin="0,5,0,15"
                               Foreground="#2C3E50"/>

                    <TextBlock Text="CLUBE DE LEITURA"
                               FontWeight="Bold"
                               FontSize="14"
                               Foreground="#B8860B"/>

                    <TextBlock Text="O clube de leitura..."
                               Foreground="#2C3E50"/>

                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</Window>
