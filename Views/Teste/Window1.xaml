<Window x:Class="ProjetoAcelera.Views.Teste.Dashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dashboard"
        Height="Auto" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#0A2A3A">

    <Grid>

        <!-- MENU SUPERIOR -->
        <StackPanel Background="#F3E6C9" Height="60" VerticalAlignment="Top">

            <!-- TÍTULO -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                <TextBlock Text="ACADEMIA DE LETRAS ARTES E HISTÓRIA DE CRUZEIRO"
                           FontWeight="Bold"
                           FontSize="16"
                           Foreground="#1F3A5F"/>
            </StackPanel>

            <!-- MENU -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                <TextBlock Text="Home" Margin="15,0"/>


         <!-- PROGRAMAÇÃO -->
        <Button Content="Programação"
                Margin="15,0"
                Background="Transparent"
                BorderThickness="0"
                Foreground="#1F3A5F"
                Cursor="Hand"
                Click="Programacao_Click"/>
                <TextBlock Text="Cultura" Margin="15,0"/>

                <!--Botão Artistas -->
                <Button Content="Artistas"
                    Margin="15,0"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="#1F3A5F"
                    Cursor="Hand"
                    Click="Artistas_Click"/>

                        <TextBlock Text="Nossa Cidade"
                        Margin="15,0"
                        Foreground="Black"
                        FontWeight="Bold"/>

                <!-- BOTÃO CONTA -->
                <Button Content="Conta"
                        Margin="15,0"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#1F3A5F"
                        Cursor="Hand"
                        Click="Conta_Click"/>
            </StackPanel>

        </StackPanel>

        <!-- CONTEÚDO -->
        <ScrollViewer Margin="0,60,0,0">
            <StackPanel>

                <!-- IMAGEM PRINCIPAL -->
                <Image Source="/ImagemAcelera/cruzeiro.png"
                       Height="500"
                       Stretch="UniformToFill"/>

                <!-- HISTÓRIA -->
                <StackPanel Margin="20">

                    <TextBlock Text="HISTÓRIA DE CRUZEIRO"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="Gold"
                               Margin="0,10"/>

                    <TextBlock TextWrapping="Wrap"
                               Foreground="White"
                               FontSize="14"
                               Text="A história de Cruzeiro começa no século XVIII, quando a região era utilizada como rota pelos tropeiros que transportavam mercadorias entre o interior de São Paulo e o litoral. Especialmente em direção a Paraty. Nesse período, o local era apenas um ponto de passagem, mas já tinha importância estratégica."/>
                </StackPanel>

                <!-- BLOCO 1 -->
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <Image Source="/ImagemAcelera/estacao.png"
                           Height="150"
                           Margin="10"
                           Stretch="Uniform"/>

                    <StackPanel Grid.Column="1" Margin="10">
                        <TextBlock Text="ESTAÇÃO FERROVIÁRIA"
                                   FontSize="18"
                                   Foreground="Gold"
                                   FontWeight="Bold"/>

                        <TextBlock TextWrapping="Wrap"
                                   Foreground="White"
                                   Text="Inaugurada no final do século XIX, foi um importante entroncamento ferroviário que ligava o Vale do Paraíba às ferrovias de Minas Gerais e Rio de Janeiro, desempenhando papel vital no transporte de café e passageiros. Hoje, integra o patrimônio cultural da cidade."/>
                    </StackPanel>
                </Grid>

                <!-- BLOCO 2 -->
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="10">
                        <TextBlock Text="ROTUNDA DE CRUZEIRO"
                                   FontSize="18"
                                   Foreground="Gold"
                                   FontWeight="Bold"/>

                        <TextBlock TextWrapping="Wrap"
                                   Foreground="White"
                                   Text="Ela é uma construção circular utilizada para abrigar e fazer a manutenção de locomotivas. Construída no século XX, foi essencial para o funcionamento da malha ferroviária da região, hoje sendo patrimônio histórico e cultural."/>
                    </StackPanel>

                    <Image Grid.Column="1"
                           Source="/ImagemAcelera/rotunda.png"
                           Height="150"
                           Margin="10"
                           Stretch="Uniform"/>
                </Grid>

                <!-- BLOCO 3 -->
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <Image Source="/ImagemAcelera/museu.png"
                           Height="150"
                           Margin="10"
                           Stretch="Uniform"/>

                    <StackPanel Grid.Column="1" Margin="10">
                        <TextBlock Text="MUSEU MAJOR NOVAES"
                                   FontSize="18"
                                   Foreground="Gold"
                                   FontWeight="Bold"/>

                        <TextBlock TextWrapping="Wrap"
                                   Foreground="White"
                                   Text="Dedicado à preservação da memória regional, reúne acervos históricos e culturais da cidade e do Vale do Paraíba."/>
                    </StackPanel>
                </Grid>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</Window>