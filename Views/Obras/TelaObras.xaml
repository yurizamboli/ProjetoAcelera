<Window x:Class="ProjetoAcelera.Views.Obras.TelaObras"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TelaObras"
        Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#0A2A3A">

    <Grid>

        <!-- CARD PRINCIPAL -->
        <Border Background="#F3E6C9"
                CornerRadius="15"
                BorderBrush="#C9B27D"
                BorderThickness="2"
                Margin="40"
                Padding="25">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- PERFIL -->
                <Grid Margin="0,0,0,25">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="130"/>
                    </Grid.ColumnDefinitions>

                    <!-- FOTO -->
                    <Border BorderBrush="#1F3A5F"
                            BorderThickness="2"
                            CornerRadius="10"
                            Margin="5"
                            ClipToBounds="True">

                        <Image Source="/ImagemAcelera/Hulkmagrelo.png"
                               Stretch="UniformToFill"/>
                    </Border>

                    <!-- INFO -->
                    <StackPanel Grid.Column="1" Margin="15,0">

                        <TextBox x:Name="txtNome"
                                IsReadOnly="True"
                                Height="35"
                                Margin="0,0,0,10"
                                Background="#EAEAEA"
                                BorderThickness="0"
                                Padding="10"
                                VerticalContentAlignment="Center" TextChanged="txtNome_TextChanged"/>

                        <TextBox Text="Biografia"
                                IsReadOnly="True"
                                Height="70"
                                AcceptsReturn="True"
                                TextWrapping="Wrap"
                                Background="#EAEAEA"
                                BorderThickness="0"
                                Padding="10"/>
                    </StackPanel>

                    <!-- BOTÕES -->
                    <StackPanel Grid.Column="2"
                                VerticalAlignment="Top"
                                Margin="10,0">

                        <Button Content="Salvar"
                                Height="35"
                                Margin="0,0,0,10"
                                Background="#1F3A5F"
                                Foreground="Gold"
                                FontWeight="Bold"
                                Click="Button_Click"/>

                        <Button Content="Editar"
                                Height="35"
                                Background="#1F3A5F"
                                Foreground="Gold"
                                FontWeight="Bold" Click="Button_Click_1"/>
                    </StackPanel>

                </Grid>

                <!-- OBRAS -->
                <Border Grid.Row="1"
                        BorderBrush="#1F3A5F"
                        BorderThickness="2"
                        CornerRadius="10"
                        Padding="15">

                    <StackPanel>

                        <TextBlock Text="Minhas Obras"
                                   FontWeight="Bold"
                                   FontSize="18"
                                   Foreground="#1F3A5F"
                                   Margin="0,0,0,15"/>

                        <!-- LISTA DINÂMICA -->
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled">

                            <!-- 🔥 AQUI É ONDE VAI CARREGAR AS OBRAS -->
                            <StackPanel x:Name="painelObras"
                                        Orientation="Horizontal"/>
                            
                        </ScrollViewer>

                    </StackPanel>
                </Border>

            </Grid>
        </Border>

    </Grid>
</Window>