<Window x:Class="ProjetoAcelera.Views.Obras.TelaObras"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TelaObras"
        Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#0A2A3A">

    <Grid>

        <!-- CARD PRINCIPAL -->
        <Border Background="#F3E6C9"
                CornerRadius="15"
                BorderBrush="#C9B27D"
                BorderThickness="2"
                Margin="40"
                Padding="25">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- PERFIL -->
                <Grid Margin="0,0,0,25">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="130"/>
                    </Grid.ColumnDefinitions>

                    <!-- FOTO -->
                    <Border BorderBrush="#1F3A5F"
                            BorderThickness="2"
                            CornerRadius="10"
                            Margin="5"
                            ClipToBounds="True">

                        <Image Source="/ImagemAcelera/Hulkmagrelo.png"
                               Stretch="UniformToFill"/>
                    </Border>

                    <!-- INFO -->
                    <StackPanel Grid.Column="1" Margin="15,0">

                        <TextBox Text="Nome"
                                 Height="35"
                                 Margin="0,0,0,10"
                                 Background="#EAEAEA"
                                 BorderThickness="0"
                                 Padding="10"
                                 VerticalContentAlignment="Center"/>

                        <TextBox Text="Biografia"
                                 Height="70"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Background="#EAEAEA"
                                 BorderThickness="0"
                                 Padding="10"/>
                    </StackPanel>

                    <!-- BOTÕES -->
                    <StackPanel Grid.Column="2"
                                VerticalAlignment="Top"
                                Margin="10,0">

                        <Button Content="Salvar"
                                Height="35"
                                Margin="0,0,0,10"
                                Background="#1F3A5F"
                                Foreground="Gold"
                                FontWeight="Bold"/>

                        <Button Content="Editar"
                                Height="35"
                                Background="#1F3A5F"
                                Foreground="Gold"
                                FontWeight="Bold"/>
                    </StackPanel>

                </Grid>

                <!-- OBRAS -->
                <Border Grid.Row="1"
                        BorderBrush="#1F3A5F"
                        BorderThickness="2"
                        CornerRadius="10"
                        Padding="15">

                    <StackPanel>

                        <TextBlock Text="Minhas Obras"
                                   FontWeight="Bold"
                                   FontSize="18"
                                   Foreground="#1F3A5F"
                                   Margin="0,0,0,15"/>

                        <!-- LISTA -->
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled">

                            <StackPanel Orientation="Horizontal">

                                <!-- BOTÃO + (MANTIDO DO ANTIGO) -->
                                <Border Width="120" Height="160"
                                        Margin="5"
                                        Background="#EAEAEA"
                                        BorderBrush="#1F3A5F"
                                        BorderThickness="2"
                                        CornerRadius="10"
                                        Cursor="Hand"
                                        MouseDown="AdicionarObra_Click">

                                    <Grid>
                                        <TextBlock Text="+"
                                                   FontSize="40"
                                                   Foreground="#1F3A5F"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <!-- OBRA 1 (EXEMPLO) -->
                                <Border Width="120" Height="160"
                                        Margin="5"
                                        CornerRadius="10"
                                        BorderBrush="#1F3A5F"
                                        BorderThickness="2"
                                        ClipToBounds="True">

                                    <Image Source="/ImagemAcelera/product_thumb_12927_68348a383fe072.97120940.jpg"
                                           Stretch="UniformToFill"/>
                                </Border>

                                <!-- OBRA 2 (VAZIA) -->
                                <Border Width="120" Height="160"
                                        Margin="5"
                                        CornerRadius="10"
                                        BorderBrush="#1F3A5F"
                                        BorderThickness="2"/>

                            </StackPanel>

                        </ScrollViewer>

                    </StackPanel>
                </Border>

            </Grid>
        </Border>

    </Grid>
</Window>