<Window x:Class="ProjetoAcelera.Views.Cadastro.TelaCadastro"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cadastro"
        Height="520" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#0A2A3A">

	<Grid>

		<!-- CARD -->
		<Border Width="700" Height="400"
                CornerRadius="10"
                Background="#F3E6C9"
                BorderBrush="#C9B27D"
                BorderThickness="3"
                Padding="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition/>
					<ColumnDefinition Width="5"/>
					<ColumnDefinition/>
				</Grid.ColumnDefinitions>

				<!-- LADO ESQUERDO (LOGO) -->
				<StackPanel Grid.Column="0"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">

					<Image Source="Image1.png"
                           Width="180"
                           Height="180"
                           Stretch="Uniform"/>
				</StackPanel>

				<!-- LINHA -->
				<Border Grid.Column="1"
                        Background="#2FA36B"
                        Width="3"
                        Margin="10,0"/>

				<!-- LADO DIREITO (CADASTRO) -->
				<StackPanel Grid.Column="2"
                            VerticalAlignment="Center"
                            Margin="30">

					<TextBlock Text="Cadastro"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#1F3A5F"
                               Margin="0,0,0,15"/>

					<!-- Nome -->
					<Border Background="#EAEAEA" CornerRadius="5" Margin="0,5">
						<TextBox x:Name="txtNome"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="10"
                                 FontSize="14"/>
					</Border>

					<!-- Email -->
					<Border Background="#EAEAEA" CornerRadius="5" Margin="0,5">
						<TextBox x:Name="txtEmail"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="10"
                                 FontSize="14"/>
					</Border>

					<!-- Senha -->
					<Border Background="#EAEAEA" CornerRadius="5" Margin="0,5">
						<PasswordBox x:Name="txtSenha"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="10"
                                     FontSize="14"/>
					</Border>

					<!-- Botão cadastrar -->
					<Button Content="CADASTRAR"
                            Height="40"
                            Margin="0,15,0,5"
                            Background="#1F3A5F"
                            Foreground="#D4AF37"
                            FontWeight="Bold"
                            BorderBrush="#C9B27D"
                            BorderThickness="2"
                            Cursor="Hand"
                            Click="BtnCadastrar_Click"/>

					<!-- Botão voltar -->
					<Button Content="Voltar"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#1F3A5F"
                            Cursor="Hand"
                            Click="BtnVoltar_Click"/>
				</StackPanel>

			</Grid>
		</Border>
	</Grid>
</Window>