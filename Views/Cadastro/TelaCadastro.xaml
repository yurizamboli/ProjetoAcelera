<Window x:Class="ProjetoAcelera.Views.Cadastro.TelaCadastro"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cadastro"
        Height="520" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#0A2A3A">

    <Grid>

        <!-- CARD -->
        <Border Width="700" Height="400"
                CornerRadius="10"
                Background="#F3E6C9"
                BorderBrush="#C9B27D"
                BorderThickness="3"
                Padding="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <!-- LADO ESQUERDO (LOGO) -->
                <StackPanel Grid.Column="0"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">

                    <Image Source=""
                           Width="180"
                           Height="180"
                           Stretch="Uniform"/>
                </StackPanel>

                <!-- LINHA -->
                <Border Grid.Column="1"
                        Background="#2FA36B"
                        Width="3"
                        Margin="10,0"/>

                <!-- LADO DIREITO (CADASTRO) -->
                <StackPanel Grid.Column="2"
                            VerticalAlignment="Center"
                            Margin="30">

                    <TextBlock Text="Cadastro"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#1F3A5F"
                               Margin="0,0,0,15"/>

                    <!-- Nome -->
                    <Border Background="#EAEAEA" CornerRadius="5" Margin="0,5">
                        <TextBox x:Name="txtNome"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="10"
                                 FontSize="14"
                                 Text="Nome"
                                 Foreground="Gray"
                                 VerticalContentAlignment="Center"
                                 GotFocus="TxtNome_GotFocus"
                                 LostFocus="TxtNome_LostFocus" TextChanged="txtNome_TextChanged"/>
                    </Border>

                    <!-- Email -->
                    <Border Background="#EAEAEA" CornerRadius="5" Margin="0,5">
                        <TextBox x:Name="txtEmail"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="10"
                                 FontSize="14"
                                 Text="Email"
                                 Foreground="Gray"
                                 VerticalContentAlignment="Center"
                                 GotFocus="TxtEmail_GotFocus"
                                 LostFocus="TxtEmail_LostFocus" TextChanged="txtEmail_TextChanged"/>
                    </Border>

                    <Border Background="#EAEAEA" CornerRadius="5" Margin="0,5">
                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="35" />
                            </Grid.ColumnDefinitions>
                            <PasswordBox x:Name="txtSenha"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="10"
                     FontSize="14"
                     VerticalContentAlignment="Center"
                     GotFocus="TxtSenha_GotFocus"
                     LostFocus="TxtSenha_LostFocus"
                     PasswordChanged="txtSenha_PasswordChanged"
                     Grid.Column="0"
                     HorizontalAlignment="Stretch"/>
                            <TextBox x:Name="txtSenhaVisivel"
                 Background="Transparent"
                 BorderThickness="0"
                 Padding="10"
                 FontSize="14"
                 VerticalContentAlignment="Center"
                 Visibility="Collapsed"
                 TextChanged="txtSenhaVisivel_TextChanged"
                 Grid.Column="0"
                 HorizontalAlignment="Stretch"/>
                            <Button Content="👁"
                Background="Transparent"
                BorderThickness="0"
                Cursor="Hand"
                Click="BtnToggleSenha_Click"
                Grid.Column="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtSenhaPlaceholder"
                   Text="Senha"
                   Foreground="Gray"
                   Margin="10,0,0,0"
                   VerticalAlignment="Center"
                   IsHitTestVisible="False"
                   Grid.ColumnSpan="2"/>
                        </Grid>
                    </Border>

                    <!-- Botão cadastrar -->
                    <Button Content="CADASTRAR"
                            Height="40"
                            Margin="0,15,0,5"
                            Background="#1F3A5F"
                            Foreground="#D4AF37"
                            FontWeight="Bold"
                            BorderBrush="#C9B27D"
                            BorderThickness="2"
                            Cursor="Hand"
                            Click="BtnCadastrar_Click"/>

                    <!-- Botão voltar -->
                    <Button Content="Voltar"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#1F3A5F"
                            Cursor="Hand"
                            Click="BtnVoltar_Click"/>
                </StackPanel>

            </Grid>
        </Border>
    </Grid>
</Window>