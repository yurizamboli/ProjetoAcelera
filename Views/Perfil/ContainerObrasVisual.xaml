<Page x:Class="ProjetoAcelera.Views.Perfil.ContainerObrasVisual"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <Border Background="#F3E6C9"
            BorderBrush="#C9B27D"
            BorderThickness="2"
            CornerRadius="18"
            Padding="15">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Obras"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#1F3A5F"
                       Margin="0,0,0,15"/>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto">

                <StackPanel>

                    <WrapPanel x:Name="painelObras"
                               Orientation="Horizontal"
                               HorizontalAlignment="Center"/>

                    <Button x:Name="btnCarregarMais"
                            Content="Carregar mais obras"
                            Height="38"
                            Width="210"
                            Margin="0,14,0,20"
                            Background="#B8860B"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            HorizontalAlignment="Center"
                            Click="BtnCarregarMais_Click"/>

                </StackPanel>

            </ScrollViewer>
        </Grid>
    </Border>
</Page>