<Page x:Class="ProjetoAcelera.Views.Perfil.ContainerPublicacoes"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">
	
	<Border BorderBrush="#C9B27D"
            BorderThickness="2"
            CornerRadius="18"
            Padding="5"
            Background="#F3E6C9">
		<Grid>
		<ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

			<StackPanel >

				<TextBlock Text="Publicações"
                           FontWeight="Bold"
                           FontSize="22"
                           Foreground="#1F3A5F"
                           Margin="0,0,0,15"/>

				<!-- ÁREA DE CRIAÇÃO -->
				<Border Background="#FFF7E1"
                        BorderBrush="#C9B27D"
                        BorderThickness="2"
                        CornerRadius="16"
                        Padding="14"
                        Margin="0,0,0,20">

					<StackPanel>

						<TextBlock Text="Criar nova publicação"
                                   Foreground="#1F3A5F"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Margin="0,0,0,8"/>

						<TextBox x:Name="txtNovaPublicacao"
                                 Height="90"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 FontSize="14"
                                 Padding="10"
                                 Background="#FFFFFF"
                                 BorderBrush="#BDAE84"
                                 BorderThickness="1"/>

						<Border Background="#E8E1CF"
                                BorderBrush="#BDAE84"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="12"
                                Margin="0,12,0,0"
                                Cursor="Hand"
                                MouseDown="AdicionarImagem_Button">

							<StackPanel Orientation="Horizontal">

								<TextBlock Text="🖼"
                                           FontSize="20"
                                           VerticalAlignment="Center"/>

								<TextBlock x:Name="txtImagemSelecionada"
                                           Text="Clique para selecionar uma imagem"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Foreground="#1F3A5F"/>

							</StackPanel>
						</Border>
                            <StackPanel Orientation="Horizontal"
             HorizontalAlignment="Right">
                                <CheckBox x:Name="chkPermiteComentarios"
                                      Content="Permitir comentários"
                                      IsChecked="True"
                                      Foreground="#1F3A5F"
                                      FontWeight="Bold"
                                      Margin="0,10,15,0"/>
                            <Button Content="Publicar"
                                Width="130"
                                Height="38"
                                Margin="0,12,0,0"
                                HorizontalAlignment="Right"
                                Background="#1F3A5F"
                                Foreground="Gold"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Click="Publicar_Button"/>
                            </StackPanel>
                        </StackPanel>
				</Border>
                    <!-- FILTRO -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,0,0,12">

                        <TextBlock Text="Filtrar:"
                                   Foreground="#1F3A5F"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>

                        <ComboBox x:Name="cmbFiltroPublicacoes"
                                    Width="190"
                                    Height="34"
                                    SelectedIndex="0"
                                    SelectionChanged="cmbFiltroPublicacoes_SelectionChanged"
                                    Background="#FFF7E1"
                                    Foreground="#1F3A5F"
                                    BorderBrush="#C9B27D"
                                    BorderThickness="2"
                                    FontWeight="Bold"
                                    FontSize="13"
                                    Padding="8,0"
                                    Cursor="Hand"
                                    VerticalContentAlignment="Center"
                                    HorizontalContentAlignment="Left">

                            <ComboBoxItem Content="Todos os posts"
                                          Background="#FFF7E1"
                                          Foreground="#1F3A5F"
                                          FontWeight="Bold"
                                          Height="32"
                                          VerticalContentAlignment="Center"
                                          HorizontalContentAlignment="Left"/>

                            <ComboBoxItem Content="Feed global"
                                          Background="#FFF7E1"
                                          Foreground="#1F3A5F"
                                          FontWeight="Bold"
                                          Height="32"
                                          VerticalContentAlignment="Center"
                                          HorizontalContentAlignment="Left"/>

                        </ComboBox>

                    </StackPanel>
                    <!-- FEED -->
				<StackPanel x:Name="painelPublicacoes"/>
                    <Button x:Name="btnCarregarMais"
                            Content="Carregar mais postagens"
                            Width="230"
                            Height="38"
                            Margin="0,14,0,20"
                            HorizontalAlignment="Center"
                            Background="#B8860B"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="BtnCarregarMais_Click"/>

                </StackPanel>

		</ScrollViewer>
		</Grid>
	</Border>
		
</Page>