<Page x:Class="ProjetoAcelera.Views.Perfil.ContainerPublicacoes"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <Border BorderBrush="#C9B27D"
            BorderThickness="2"
            CornerRadius="18"
            Padding="18"
            Background="#F3E6C9">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Publicações"
                       FontWeight="Bold"
                       FontSize="22"
                       Foreground="#1F3A5F"
                       Margin="0,0,0,15"/>

            <!-- ÁREA DE CRIAÇÃO -->
            <Border Grid.Row="1"
                    Background="#FFF7E1"
                    BorderBrush="#C9B27D"
                    BorderThickness="2"
                    CornerRadius="16"
                    Padding="14"
                    Margin="0,0,0,20">

                <StackPanel>

                    <TextBlock Text="Criar nova publicação"
                               Foreground="#1F3A5F"
                               FontWeight="Bold"
                               FontSize="14"
                               Margin="0,0,0,8"/>

                    <TextBox x:Name="txtNovaPublicacao"
                             Height="90"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             FontSize="14"
                             Padding="10"
                             Background="#FFFFFF"
                             BorderBrush="#BDAE84"
                             BorderThickness="1"/>

                    <!-- SELETOR DE IMAGEM -->
                    <Border Background="#E8E1CF"
                            BorderBrush="#BDAE84"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12"
                            Margin="0,12,0,0"
                            Cursor="Hand"
                            MouseDown="AdicionarImagem_Button">

                        <StackPanel Orientation="Horizontal">

                            <TextBlock Text="🖼"
                                       FontSize="20"
                                       VerticalAlignment="Center"/>

                            <TextBlock x:Name="txtImagemSelecionada"
                                       Text="Clique para selecionar uma imagem"
                                       Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Foreground="#1F3A5F"/>

                        </StackPanel>
                    </Border>

                    <Button Content="Publicar"
                            Width="130"
                            Height="38"
                            Margin="0,12,0,0"
                            HorizontalAlignment="Right"
                            Background="#1F3A5F"
                            Foreground="Gold"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Click="Publicar_Button"/>

                </StackPanel>
            </Border>

            <!-- FEED -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">

                <StackPanel x:Name="painelPublicacoes"
                            Margin="0,0,0,35"/>

            </ScrollViewer>

        </Grid>
    </Border>
</Page>