<Window x:Class="ProjetoAcelera.Views.Perfil.TelaPerfil"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TelaPerfil"
        Height="800" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#0A2A3A">

    <Grid>

        <!-- CARD PRINCIPAL -->
        <Border Background="#F3E6C9"
                CornerRadius="15"
                BorderBrush="#C9B27D"
                BorderThickness="2"
                Margin="40"
                Padding="25">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- PERFIL -->
                <Grid Margin="0,0,0,25">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="130"/>
                    </Grid.ColumnDefinitions>

                    <!-- FOTO -->
                    <Border BorderBrush="#1F3A5F"
                            BorderThickness="2"
                            CornerRadius="10"
                            Margin="5"
                            Width="140"
                            Height="140"
                            ClipToBounds="True"
                            VerticalAlignment="top">

                        <Image 
                            x:Name="imgPerfil"
                            Source="/ImagemAcelera/Hulkmagrelo.png"
                            Stretch="UniformToFill"/>
                    </Border>

                    
                    <StackPanel Grid.Column="1" Margin="15,0">
                        <TextBlock Text="Nome" Margin="0,0,0,0" Foreground="Black"/>
                        <TextBlock x:Name="txtNome"                                 
                                   Height="35"
                                   Margin="0,0,0,5"
                                   Background="#EAEAEA"                                   
                                   Padding="10"/>       
                        <TextBlock Text="Biografia" Margin="0,0,0,0" Foreground="Black"/>
                        <TextBlock x:Name="txtBiografia"  
                                   Height="70"                                  
                                   TextWrapping="Wrap"
                                   Background="#EAEAEA"                                 
                                   Padding="10"/>
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                            <StackPanel Margin="0,0,20,0">
                                <TextBlock Text="Facebook" Margin="0,0,0,0"/>
                                <TextBlock x:Name="textBlockFacebook" 
                                           Width="164"
                                           Padding="10"
                                           Background="#EAEAEA"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Instagram" Margin="0,0,0,0"/>
                                <TextBlock x:Name="textBlockInstagram"
                                           Width="164"
                                           Padding="10"
                                           Background="#EAEAEA"/>
                            </StackPanel>

                        </StackPanel>

                    </StackPanel>
                    <!-- BOTÕES -->
                    <StackPanel Grid.Column="2"
                                VerticalAlignment="Top"
                                Margin="10,0">

                        <Button Content="Sair"
                                Height="35"
                                Margin="0,17,0,10"
                                Background="#1F3A5F"
                                Foreground="Gold"
                                FontWeight="Bold"
                                Click="Logout_Button"/>
                        <Button Content="Editar"
                                Height="35"
                                Background="#1F3A5F"
                                Foreground="Gold"
                                FontWeight="Bold" Click="EditarPerfil_Button"/>

                                <Button Content="Voltar"
                                    Width="120"
                                    Height="35"
                                    Margin="0,10,0,0"
                                    Background="#1F3A5F"
                                    Foreground="Gold"
                                    Click="Voltar_Click"/>
                    </StackPanel>

                </Grid>

                <!-- OBRAS -->
                <Border Grid.Row="1"
                        BorderBrush="#1F3A5F"
                        BorderThickness="2"
                        CornerRadius="10"
                        Padding="15">

                    <StackPanel>

                        <TextBlock Text="Minhas Obras"
                                   FontWeight="Bold"
                                   FontSize="18"
                                   Foreground="#1F3A5F"
                                   Margin="0,0,0,15"/>

                        <!-- LISTA DINÂMICA -->
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled">

                            <!-- AQUI É ONDE VAI CARREGAR AS OBRAS -->
                            <StackPanel x:Name="painelObras"
                                        Orientation="Horizontal"/>

                        </ScrollViewer>

                    </StackPanel>
                </Border>

            </Grid>
        </Border>

    </Grid>
</Window>