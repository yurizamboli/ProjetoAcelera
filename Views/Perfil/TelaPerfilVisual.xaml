<Window x:Class="ProjetoAcelera.Views.Perfil.TelaPerfilVisual"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Perfil do Artista"
        Height="700" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#0A2A3A">

    <Grid>

        <Border Background="#F3E6C9"
                CornerRadius="15"
                Margin="30"
                Padding="20">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- PERFIL -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- FOTO -->
                    <Border Width="140" Height="140"
                            CornerRadius="10"
                            ClipToBounds="True"
                            BorderBrush="#1F3A5F"
                            BorderThickness="2">

                        <Image x:Name="imgPerfil"
                               Stretch="UniformToFill"/>
                    </Border>

                    <!-- INFO -->
                    <StackPanel Grid.Column="1" Margin="15,0">

                        <TextBlock Text="Nome"/>
                        <TextBlock x:Name="txtNome"
                                   Background="#EAEAEA"
                                   Padding="10"
                                   Margin="0,5"/>

                        <TextBlock Text="Biografia"/>
                        <TextBlock x:Name="txtBio"
                                   Background="#EAEAEA"
                                   Padding="10"
                                   TextWrapping="Wrap"
                                   Height="70"/>

                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">

                            <StackPanel Margin="0,0,20,0">
                                <TextBlock Text="Facebook"/>
                                <TextBlock x:Name="txtFacebook"
                                           Background="#EAEAEA"
                                           Padding="5"
                                           Width="150"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Instagram"/>
                                <TextBlock x:Name="txtInstagram"
                                           Background="#EAEAEA"
                                           Padding="5"
                                           Width="150"/>
                            </StackPanel>

                        </StackPanel>

                    </StackPanel>
                </Grid>

                <!-- OBRAS -->
                <StackPanel Grid.Row="1" Margin="0,20,0,0">

                    <TextBlock Text="Obras"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#1F3A5F"
                               Margin="0,0,0,10"/>

                    <ScrollViewer HorizontalScrollBarVisibility="Auto">
                        <StackPanel x:Name="painelObras"
                                    Orientation="Horizontal"/>
                    </ScrollViewer>

                </StackPanel>

            </Grid>

        </Border>

    </Grid>
</Window>