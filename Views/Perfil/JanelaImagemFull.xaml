<Window x:Class="ProjetoAcelera.Views.Perfil.JanelaImagemFull"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#0A2A3A"
        SizeToContent="WidthAndHeight">

	<Grid Margin="10">
		<Border Background="#111111"
                CornerRadius="12"
                Padding="10">

			<Grid>
				<Image x:Name="imgGaleria"
                       Stretch="Uniform"
                       MaxWidth="900"
                       MaxHeight="650"/>

				<Button Content="X"
                        Width="28"
                        Height="28"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,8,8,0"
                        Background="#66000000"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="Bold"
                        Click="Fechar_Click"/>
			</Grid>
		</Border>
	</Grid>
</Window>