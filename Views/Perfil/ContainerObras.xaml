<Page x:Class="ProjetoAcelera.Views.Perfil.ContainerObras"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <Border BorderBrush="#1F3A5F"
            BorderThickness="2"
            CornerRadius="10"
            Padding="15"
            Background="#F3E6C9">

        <StackPanel>

            <TextBlock Text="Minhas Obras"
                       FontWeight="Bold"
                       FontSize="18"
                       Foreground="#1F3A5F"
                       Margin="0,0,0,15"/>

            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">

                <StackPanel x:Name="painelObras"
                            Orientation="Horizontal"/>

            </ScrollViewer>

        </StackPanel>

    </Border>

</Page>