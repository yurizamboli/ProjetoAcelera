<Page x:Class="ProjetoAcelera.Views.Perfil.ContainerObras"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <Border BorderBrush="#1F3A5F"
            BorderThickness="2"
            CornerRadius="10"
            Padding="15"
            Background="#F3E6C9">

        <StackPanel>

            <TextBlock Text="Minhas Obras"
                       FontWeight="Bold"
                       FontSize="18"
                       Foreground="#1F3A5F"
                       Margin="0,0,0,15"/>

            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto"
                          MaxHeight="500">
                <StackPanel>
                    <WrapPanel x:Name="painelObras"
                             Orientation="Horizontal"
                           HorizontalAlignment="Center"/>

                <Button x:Name="btnCarregarMais"
                        Content="Carregar mais obras"
                        Height="38"
                        Width="210"
                        Margin="0,14,0,20"
                        Background="#B8860B"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand"
                        HorizontalAlignment="Center"
                        Click="BtnCarregarMais_Click"/>
                </StackPanel>
            </ScrollViewer>
            
        </StackPanel>

    </Border>

</Page>