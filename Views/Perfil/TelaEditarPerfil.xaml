<Window x:Class="ProjetoAcelera.Views.Perfil.EditarPerfil.TelaEditarPerfil"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Editar Perfil"
        Height="600"
        Width="1000"
        WindowStartupLocation="CenterScreen">
    <Window.Background>
        <ImageBrush ImageSource="/ImagemAcelera/solid-navy-blue-concrete-textured-wall.jpg"
                Stretch="UniformToFill"/>
    </Window.Background>
    <Grid>
        <Border Width="780"
                Height="455"
                CornerRadius="22"
                Background="#F3E6C9"
                BorderBrush="#C9B27D"
                BorderThickness="3"
                Padding="25"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="230"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- FOTO -->
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                    <Border Width="180"
                            Height="180"
                            BorderBrush="#1F3A5F"
                            BorderThickness="3"
                            CornerRadius="16"
                            Background="#D8D3C7"
                            ClipToBounds="True"
                            Margin="0,0,0,15">

                        <Image x:Name="imgPreview"
                               Stretch="UniformToFill"/>
                    </Border>

                    <Button Content="Escolher Foto"
                            Width="145"
                            Height="36"
                            Background="#1F3A5F"
                            Foreground="Gold"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="EscolherFoto_Click"/>
                </StackPanel>

                <!-- CAMPOS -->
                <StackPanel Grid.Column="1"
                            Margin="25,0,0,0">

                    <TextBlock Text="Editar Perfil"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="#1F3A5F"
                               Margin="0,0,0,20"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="Nome"
                               Foreground="#1F3A5F"
                               FontWeight="Bold"/>

                    <TextBox x:Name="txtNome"
                             Height="36"
                             Background="#E8E1CF"
                             BorderBrush="#BDAE84"
                             BorderThickness="1"
                             Padding="10"
                             Margin="0,4,0,10"/>

                    <TextBlock Text="Biografia"
                               Foreground="#1F3A5F"
                               FontWeight="Bold"/>

                    <TextBox x:Name="txtBio"
                             Height="100"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Background="#E8E1CF"
                             BorderBrush="#BDAE84"
                             BorderThickness="1"
                             Padding="10"
                             Margin="0,4,0,10"/>

                    <StackPanel Orientation="Horizontal">
                        <StackPanel Margin="0,0,15,0">
                            <TextBlock Text="Facebook"
                                       Foreground="#1F3A5F"
                                       FontWeight="Bold"/>

                            <TextBox x:Name="txtFacebook"
                                     Width="185"
                                     Height="34"
                                     Background="#E8E1CF"
                                     BorderBrush="#BDAE84"
                                     BorderThickness="1"
                                     Padding="8"
                                     Margin="0,4,0,0"/>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="Instagram"
                                       Foreground="#1F3A5F"
                                       FontWeight="Bold"/>

                            <TextBox x:Name="txtInstagram"
                                     Width="185"
                                     Height="34"
                                     Background="#E8E1CF"
                                     BorderBrush="#BDAE84"
                                     BorderThickness="1"
                                     Padding="8"
                                     Margin="0,4,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,25,0,0">

                        <Button Content="Salvar"
                                Width="125"
                                Height="38"
                                Margin="0,0,12,0"
                                Background="#1F3A5F"
                                Foreground="Gold"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="Salvar_Click"/>

                        <Button Content="Cancelar"
                                Width="125"
                                Height="38"
                                Background="#1F3A5F"
                                Foreground="Gold"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="Cancelar_Click"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>