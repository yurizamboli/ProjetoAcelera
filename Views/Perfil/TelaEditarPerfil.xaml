<Window x:Class="ProjetoAcelera.Views.Perfil.EditarPerfil.TelaEditarPerfil"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Editar Perfil"
        Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#0A2A3A">

    <Grid>


        <Border Width="750" Height="400"
                CornerRadius="10"
                Background="#F3E6C9"
                BorderBrush="#C9B27D"
                BorderThickness="3"
                Padding="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- container da foto-->
                <StackPanel HorizontalAlignment="Center"
                            Margin="0,10,0,0">
                    <Border Width="120" Height="120"
                            BorderBrush="#1F3A5F"
                            BorderThickness="2"
                            CornerRadius="10"
                            ClipToBounds="True"
                            Margin="0,0,0,10">
                        <Image x:Name="imgPreview"
                               Stretch="UniformToFill"/>
                    </Border>
                    <Button Content="Escolher Foto"
                            Width="120"
                            Height="30
                            "
                            Click="EscolherFoto_Click"/>
                </StackPanel>

                <!-- container dos campos -->
                <StackPanel Grid.Column="1" Margin="20,0,0,0">
                    <TextBlock Text="Editar Perfil"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#1F3A5F"
                               Margin="0,0,0,15"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Nome"/>
                    <TextBox x:Name="txtNome"
                             Height="35"
                             Background="#EAEAEA"
                             BorderThickness="0"
                             Padding="10"
                             Margin="0,5,0,10"/>
                    <TextBlock Text="Biografia"/>
                    <TextBox x:Name="txtBio"
                             Height="100"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Background="#EAEAEA"
                             BorderThickness="0"
                             Padding="10"
                             Margin="0,5,0,10"/>
                    <StackPanel Orientation="Horizontal">
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="Facebook"/>
                            <TextBox x:Name="txtFacebook"
                                     Width="180"
                                     Background="#EAEAEA"
                                     BorderThickness="0"
                                     Padding="5"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Instagram"/>
                            <TextBox x:Name="txtInstagram"
                                     Width="180"
                                     Background="#EAEAEA"
                                     BorderThickness="0"
                                     Padding="5"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,20,0,0">
                        <Button Content="Salvar"
                                Width="120"
                                Height="35"
                                Margin="0,0,10,0"
                                Background="#1F3A5F"
                                Foreground="Gold"
                                FontWeight="Bold"
                                Click="Salvar_Click"/>
                        <Button Content="Cancelar"
                                Width="120"
                                Height="35"
                                Background="#1F3A5F"
                                Foreground="Gold"
                                FontWeight="Bold"
                                Click="Cancelar_Click"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>