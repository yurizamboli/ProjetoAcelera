<Page x:Class="ProjetoAcelera.Views.Perfil.ContainerGaleria"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <Border Background="#F3E6C9"
            BorderBrush="#C9B27D"
            BorderThickness="2"
            CornerRadius="18"
            Padding="15">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Galeria"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#1F3A5F"
                       Margin="0,0,0,15"/>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto">

                <WrapPanel x:Name="painelGaleria"
                           HorizontalAlignment="Center"/>

            </ScrollViewer>
        </Grid>
    </Border>
</Page>